{
  "version": "2.1.0",
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/master/Schemata/sarif-schema-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "parsentry",
          "version": "0.1.0",
          "rules": [
            {
              "id": "RCE",
              "name": "InsecureDeserialization",
              "shortDescription": {
                "text": "Insecure deserialization allowing arbitrary code execution"
              },
              "fullDescription": {
                "text": "Deserializing untrusted data with pickle.loads() allows an attacker to craft a malicious payload that executes arbitrary Python code on the server during deserialization."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "helpUri": "https://owasp.org/www-community/vulnerabilities/Deserialization_of_untrusted_data"
            },
            {
              "id": "INPUT-VALIDATION",
              "name": "MissingInputValidation",
              "shortDescription": {
                "text": "No validation or sanitization of user-supplied data before dangerous operation"
              },
              "fullDescription": {
                "text": "User-controlled input is passed directly to a security-sensitive function without any validation, type checking, length limits, or authentication."
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/20.html"
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "RCE",
          "level": "error",
          "message": {
            "text": "pickle.loads() is called on base64-decoded user-controlled input at POST /api/pickle/deserialize. An attacker can supply a crafted base64-encoded pickle payload that uses __reduce__ to execute arbitrary OS commands or Python code upon deserialization, achieving full Remote Code Execution (RCE) on the server. No authentication, HMAC signature, or type-allowlist guards are present."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "api.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 155,
                  "endLine": 155,
                  "startColumn": 15,
                  "endColumn": 36
                }
              },
              "logicalLocations": [
                {
                  "name": "deserialize_pickle",
                  "kind": "function"
                }
              ]
            }
          ],
          "partialFingerprints": {
            "primaryLocationLineHash": "pickle.loads(decoded)"
          },
          "properties": {
            "confidence": 0.99,
            "attack_vector": "network",
            "attack_complexity": "low",
            "privileges_required": "none",
            "user_interaction": "none",
            "scope": "changed",
            "impact": "critical",
            "cwe": ["CWE-502"],
            "owasp": ["A8:2017-Insecure Deserialization", "A08:2021-Software and Data Integrity Failures"]
          }
        },
        {
          "ruleId": "RCE",
          "level": "error",
          "message": {
            "text": "base64.b64decode() converts attacker-controlled string input into raw bytes that are immediately deserialized by pickle.loads(). The complete data flow from HTTP request JSON body → data.get('data') → base64.b64decode() → pickle.loads() is fully attacker-controlled with zero intermediate validation. Publicly available tools can generate pickle RCE payloads trivially."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "api.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 154,
                  "endLine": 154,
                  "startColumn": 19,
                  "endColumn": 48
                }
              },
              "logicalLocations": [
                {
                  "name": "deserialize_pickle",
                  "kind": "function"
                }
              ]
            }
          ],
          "partialFingerprints": {
            "primaryLocationLineHash": "base64.b64decode(pickle_data)"
          },
          "properties": {
            "confidence": 0.99,
            "cwe": ["CWE-502"]
          }
        },
        {
          "ruleId": "INPUT-VALIDATION",
          "level": "warning",
          "message": {
            "text": "The /api/pickle/deserialize endpoint has no authentication or authorization check. Any unauthenticated network client can send a POST request with arbitrary pickle data. Combined with the pickle.loads() call, this means any anonymous attacker can achieve RCE without needing credentials."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "api.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 149,
                  "endLine": 151,
                  "startColumn": 1,
                  "endColumn": 1
                }
              },
              "logicalLocations": [
                {
                  "name": "deserialize_pickle",
                  "kind": "function"
                }
              ]
            }
          ],
          "partialFingerprints": {
            "primaryLocationLineHash": "data.get('data','')"
          },
          "properties": {
            "confidence": 0.95,
            "cwe": ["CWE-20", "CWE-306"]
          }
        }
      ],
      "artifacts": [
        {
          "location": {
            "uri": "api.py",
            "uriBaseId": "%SRCROOT%"
          },
          "length": 326,
          "mimeType": "text/x-python"
        }
      ]
    }
  ]
}