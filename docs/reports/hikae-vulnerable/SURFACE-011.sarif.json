{
  "version": "2.1.0",
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/master/Schemata/sarif-schema-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "parsentry",
          "version": "0.1.0",
          "rules": [
            {
              "id": "RCE",
              "name": "RemoteCodeExecution",
              "shortDescription": {
                "text": "Remote Code Execution via eval()"
              },
              "fullDescription": {
                "text": "User-supplied input is passed directly to Python's eval() builtin, enabling arbitrary code execution with the full privileges of the running process."
              },
              "defaultConfiguration": {
                "level": "error"
              }
            },
            {
              "id": "HARDCODED_SECRET",
              "name": "HardcodedSecret",
              "shortDescription": {
                "text": "Hardcoded cryptographic secret"
              },
              "fullDescription": {
                "text": "JWT signing secrets and API keys are hardcoded in source code, making them easily discoverable and non-rotatable."
              },
              "defaultConfiguration": {
                "level": "error"
              }
            },
            {
              "id": "INFO_DISCLOSURE",
              "name": "InformationDisclosure",
              "shortDescription": {
                "text": "Sensitive information disclosure in error responses"
              },
              "fullDescription": {
                "text": "Exception details and stack traces are returned directly in HTTP responses, leaking internal implementation details."
              },
              "defaultConfiguration": {
                "level": "warning"
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "RCE",
          "level": "error",
          "message": {
            "text": "Direct eval() of user-supplied 'code' parameter at POST /api/eval/python. An attacker can execute arbitrary Python expressions with full process privileges, enabling file system access, network calls, process spawning, and complete host compromise. No authentication, sandboxing, or input validation is present."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "api.py"
                },
                "region": {
                  "startLine": 270,
                  "endLine": 281,
                  "startColumn": 1,
                  "endColumn": 54
                }
              },
              "logicalLocations": [
                {
                  "name": "eval_python",
                  "kind": "function"
                }
              ]
            }
          ],
          "properties": {
            "confidence": 1.0,
            "attack_vector": "network",
            "impact": "full_system_compromise",
            "cvss_vector": "CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:C/C:H/I:H/A:H"
          }
        },
        {
          "ruleId": "HARDCODED_SECRET",
          "level": "error",
          "message": {
            "text": "JWT_SECRET ('super_secret_key_123') and API_KEYS are hardcoded in source. Any user with read access to the repository or the deployed binary can forge arbitrary JWT tokens with any role, including 'admin', enabling full authentication bypass across all protected endpoints."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "api.py"
                },
                "region": {
                  "startLine": 29,
                  "endLine": 33,
                  "startColumn": 1,
                  "endColumn": 42
                }
              },
              "logicalLocations": [
                {
                  "name": "module",
                  "kind": "module"
                }
              ]
            }
          ],
          "properties": {
            "confidence": 1.0,
            "attack_vector": "local_or_network",
            "impact": "authentication_bypass"
          }
        },
        {
          "ruleId": "INFO_DISCLOSURE",
          "level": "warning",
          "message": {
            "text": "The eval_python exception handler returns str(e) directly in the JSON response body. Runtime Python exceptions (NameError, AttributeError, etc.) can leak class names, attribute paths, and internal module structure to the caller, aiding further exploitation."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "api.py"
                },
                "region": {
                  "startLine": 280,
                  "endLine": 281,
                  "startColumn": 9,
                  "endColumn": 54
                }
              },
              "logicalLocations": [
                {
                  "name": "eval_python",
                  "kind": "function"
                }
              ]
            }
          ],
          "properties": {
            "confidence": 0.95,
            "attack_vector": "network",
            "impact": "information_disclosure"
          }
        }
      ],
      "artifacts": [
        {
          "location": {
            "uri": "api.py",
            "uriBaseId": "%SRCROOT%"
          },
          "length": 326,
          "mimeType": "text/x-python"
        }
      ]
    }
  ]
}
