  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "parsentry",
          "version": "0.1.0",
          "informationUri": "https://github.com/HikaruEgashira/parsentry",
          "rules": [
            {
              "id": "SSTI",
              "name": "ServerSideTemplateInjection",
              "shortDescription": {
                "text": "Server-Side Template Injection via unsandboxed Jinja2 rendering"
              },
              "fullDescription": {
                "text": "User-controlled input is passed directly to jinja2.Template() constructor and rendered without sandboxing. An attacker can inject Jinja2 template directives (e.g. {{config}}, {{''.__class__.__mro__[1].__subclasses__()}}) to achieve arbitrary code execution on the server. Jinja2's SandboxedEnvironment must be used instead of raw Template() when rendering untrusted input."
              },
              "helpUri": "https://owasp.org/www-project-web-security-testing-guide/latest/4-Web_Application_Security_Testing/07-Input_Validation_Testing/18-Testing_for_Server-side_Template_Injection",
              "properties": {
                "tags": ["security", "CWE-1336", "SSTI", "RCE"]
              }
            },
            {
              "id": "RCE-EVAL",
              "name": "ArbitraryCodeExecution",
              "shortDescription": {
                "text": "Arbitrary code execution via eval() of user-controlled input"
              },
              "fullDescription": {
                "text": "User-supplied input from the HTTP request body is passed directly to Python's eval() built-in function. This allows an attacker to execute arbitrary Python expressions, including importing modules and executing system commands (e.g. __import__('os').system('...')). eval() must never be used on untrusted input."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/95.html",
              "properties": {
                "tags": ["security", "CWE-95", "RCE", "code-injection"]
              }
            },
            {
              "id": "RCE-CMDI",
              "name": "OSCommandInjection",
              "shortDescription": {
                "text": "OS command injection via subprocess.run with shell=True"
              },
              "fullDescription": {
                "text": "User-supplied input is passed directly to subprocess.run() with shell=True, allowing an attacker to inject arbitrary shell commands using metacharacters (;, |, &&, $(), etc.). This provides full remote code execution on the server. Commands should be passed as a list without shell=True, and user input must never be included in shell command strings."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/78.html",
              "properties": {
                "tags": ["security", "CWE-78", "RCE", "command-injection"]
              }
            },
            {
              "id": "SSRF",
              "name": "ServerSideRequestForgery",
              "shortDescription": {
                "text": "Server-Side Request Forgery via unvalidated URL in requests.get()"
              },
              "fullDescription": {
                "text": "User-supplied URL is passed directly to requests.get() without validation. An attacker can access internal services (http://localhost, http://169.254.169.254 for cloud metadata), scan internal networks, or exfiltrate data via DNS. URL schemes, hosts, and IP ranges must be validated against an allowlist before making server-side HTTP requests."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/918.html",
              "properties": {
                "tags": ["security", "CWE-918", "SSRF"]
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "SSTI",
          "level": "error",
          "message": {
            "text": "Attacker-controlled 'template' parameter from request JSON body is passed to jinja2.Template() constructor (line 295) and rendered via t.render() (line 296) without sandboxing. This enables full server-side template injection: an attacker can read server config ({{config}}), access Python object hierarchy ({{''.__class__.__mro__[1].__subclasses__()}}), and achieve RCE ({{cycler.__init__.__globals__.os.popen('id').read()}}). Fix: use jinja2.SandboxedEnvironment or refuse to compile untrusted template strings entirely."
          },
