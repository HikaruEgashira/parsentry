          "rules": [
            {
              "id": "SQLI",
              "name": "SQLInjection",
              "shortDescription": {
                "text": "SQL Injection via string interpolation"
              },
              "fullDescription": {
                "text": "User-controlled input is interpolated directly into SQL query strings using f-strings, enabling an attacker to manipulate query logic, extract data, or modify the database."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/89.html",
              "properties": {
                "tags": ["security", "sql-injection", "CWE-89"]
              }
            },
            {
              "id": "PLAINTEXT_CREDENTIALS",
              "name": "PlaintextCredentialStorage",
              "shortDescription": {
                "text": "Passwords and API keys stored in plaintext"
              },
              "fullDescription": {
                "text": "The users table schema stores passwords, API keys, and session tokens as plain TEXT columns without hashing or encryption. An attacker who gains read access to the database obtains all credentials directly."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/256.html",
              "properties": {
                "tags": ["security", "plaintext-password", "CWE-256"]
              }
            },
            {
              "id": "HARDCODED_CREDENTIALS",
              "name": "HardcodedCredentials",
              "shortDescription": {
                "text": "Hardcoded credentials in source code"
              },
              "fullDescription": {
                "text": "Default usernames, passwords, and API keys are embedded directly in source code. These credentials are trivially discoverable and provide immediate access to the application."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/798.html",
              "properties": {
                "tags": ["security", "hardcoded-credentials", "CWE-798"]
              }
            },
            {
              "id": "SENSITIVE_DATA_LOG",
              "name": "SensitiveDataInLogs",
              "shortDescription": {
                "text": "Sensitive data written to logs"
              },
              "fullDescription": {
                "text": "SQL queries containing passwords or detailed error messages are written to application logs, risking credential exposure through log files, monitoring systems, or log aggregation services."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/532.html",
              "properties": {
                "tags": ["security", "information-disclosure", "CWE-532"]
              }
            },
            {
              "id": "INFO_EXPOSURE",
              "name": "SensitiveDataExposure",
              "shortDescription": {
                "text": "API key returned in authentication response"
              },
              "fullDescription": {
                "text": "The authenticate_user function returns the user's API key in its response dictionary. Any code path that serializes this response (e.g., JSON API) will leak the API key to the client."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/200.html",
              "properties": {
                "tags": ["security", "information-exposure", "CWE-200"]
              }
            },
            {
              "id": "DESERIALIZE",
              "name": "UnsafeDeserialization",
              "shortDescription": {
                "text": "Unsafe pickle deserialization of user input"
              },
              "fullDescription": {
                "text": "User-supplied preferences string is deserialized via pickle.loads(), which can execute arbitrary code. An attacker can craft a malicious pickle payload to achieve remote code execution."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/502.html",
              "properties": {
                "tags": ["security", "deserialization", "RCE", "CWE-502"]
              }
            },
            {
              "id": "LFI",
              "name": "LocalFileInclusion",
              "shortDescription": {
                "text": "Arbitrary file read via unvalidated file path from database"
              },
              "fullDescription": {
                "text": "A file path retrieved from the database (which can be controlled via SQL injection) is passed directly to open() without path traversal validation, allowing an attacker to read arbitrary files on the server."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/22.html",
              "properties": {
                "tags": ["security", "path-traversal", "LFI", "CWE-22"]
              }
            },
            {
              "id": "IDOR",
              "name": "InsecureDirectObjectReference",
              "shortDescription": {
                "text": "Missing authorization check on document search"
              },
              "fullDescription": {
                "text": "The search_documents function accepts a user_id parameter but never uses it to filter results, allowing any authenticated user to search and access all documents regardless of ownership."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/639.html",
              "properties": {
                "tags": ["security", "authorization", "IDOR", "CWE-639"]
              }
            }
          ]
        }
