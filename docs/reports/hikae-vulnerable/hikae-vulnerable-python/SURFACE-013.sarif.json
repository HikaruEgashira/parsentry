  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "parsentry",
          "version": "0.1.0",
          "informationUri": "https://github.com/HikaruEgashira/parsentry",
          "rules": [
            {
              "id": "SQLI",
              "name": "SQLInjection",
              "shortDescription": {
                "text": "SQL Injection via string interpolation in log retrieval"
              },
              "fullDescription": {
                "text": "User-controlled input (user_id) is interpolated directly into a SQL query string using f-string formatting without parameterization, allowing an attacker to inject arbitrary SQL commands such as UNION-based data extraction or boolean-blind enumeration of all audit_logs records."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/89.html",
              "properties": {
                "tags": ["security", "CWE-89", "OWASP-A03"]
              }
            },
            {
              "id": "IDOR",
              "name": "InsecureDirectObjectReference",
              "shortDescription": {
                "text": "Missing authorization check on audit log access"
              },
              "fullDescription": {
                "text": "The /api/logs/<user_id> endpoint accepts an arbitrary user_id from the URL path and returns that user's audit logs without verifying the caller's identity or authorization. Any unauthenticated caller can enumerate and retrieve audit logs of any user, exposing sensitive actions, IP addresses, and timestamps."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/639.html",
              "properties": {
                "tags": ["security", "CWE-639", "OWASP-A01"]
              }
            },
            {
              "id": "INFO-DISCLOSURE",
              "name": "InformationDisclosure",
              "shortDescription": {
                "text": "Exception details leaked to API client"
              },
              "fullDescription": {
                "text": "The endpoint catches all exceptions and returns the raw exception message in the JSON error response. This can reveal internal database schema, table names, SQL syntax errors, and file paths to an attacker, aiding further exploitation of the SQL injection vulnerability."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/209.html",
              "properties": {
                "tags": ["security", "CWE-209", "OWASP-A04"]
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "SQLI",
          "ruleIndex": 0,
          "level": "error",
          "message": {
            "text": "The user_id parameter from the URL path is interpolated directly into a SQL query via f-string (f\"SELECT * FROM audit_logs WHERE user_id = {user_id}\"). An attacker can inject SQL such as '1 UNION SELECT * FROM users--' to extract data from other tables including credentials and API keys. Use parameterized queries (cursor.execute(\"SELECT ... WHERE user_id = ?\", (user_id,))) instead."
          },
