{
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/main/sarif-2.1/schema/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "parsentry",
          "version": "0.1.0",
          "informationUri": "https://github.com/HikaruEgashira/parsentry",
          "rules": [
            {
              "id": "SQLI",
              "name": "SQLInjection",
              "shortDescription": {
                "text": "SQL Injection via string interpolation"
              },
              "fullDescription": {
                "text": "User-controlled input is interpolated directly into a SQL query string using f-string formatting, allowing an attacker to inject arbitrary SQL commands."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/89.html",
              "properties": {
                "tags": ["security", "CWE-89", "OWASP-A03"]
              }
            },
            {
              "id": "IDOR",
              "name": "InsecureDirectObjectReference",
              "shortDescription": {
                "text": "Missing authorization check on object reference"
              },
              "fullDescription": {
                "text": "The endpoint accepts an integer user_id parameter and returns user data without verifying that the authenticated caller is authorized to access that user's record. Any caller can enumerate and retrieve arbitrary user records."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/639.html",
              "properties": {
                "tags": ["security", "CWE-639", "OWASP-A01"]
              }
            },
            {
              "id": "SENSITIVE-LOG",
              "name": "SensitiveDataLogging",
              "shortDescription": {
                "text": "Sensitive data written to log output"
              },
              "fullDescription": {
                "text": "Credentials or SQL queries containing credentials are logged via logger.debug, exposing secrets in log files."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/532.html",
              "properties": {
                "tags": ["security", "CWE-532"]
              }
            },
            {
              "id": "INFO-DISCLOSURE",
              "name": "InformationDisclosure",
              "shortDescription": {
                "text": "API key and error details exposed to callers"
              },
              "fullDescription": {
                "text": "The authentication response includes the user's api_key field, and database exception messages are logged with full detail, potentially disclosing internal structure."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/200.html",
              "properties": {
                "tags": ["security", "CWE-200"]
              }
            },
            {
              "id": "RCE",
              "name": "RemoteCodeExecution",
              "shortDescription": {
                "text": "Arbitrary code execution via eval()"
              },
              "fullDescription": {
                "text": "The eval() builtin is called with user-supplied input, allowing an attacker to execute arbitrary Python code on the server."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/94.html",
              "properties": {
                "tags": ["security", "CWE-94", "OWASP-A03"]
              }
            },
            {
              "id": "SSRF",
              "name": "ServerSideRequestForgery",
              "shortDescription": {
                "text": "Unvalidated URL passed to requests.get"
              },
              "fullDescription": {
                "text": "A URL derived from user input is passed to requests.get without validation, allowing an attacker to make the server issue requests to internal services or arbitrary hosts."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/918.html",
              "properties": {
                "tags": ["security", "CWE-918", "OWASP-A10"]
              }
            },
            {
              "id": "CMDI",
              "name": "CommandInjection",
              "shortDescription": {
                "text": "OS command injection via subprocess.run"
              },
              "fullDescription": {
                "text": "User-controlled input is passed to subprocess.run, potentially allowing an attacker to inject arbitrary OS commands."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/78.html",
              "properties": {
                "tags": ["security", "CWE-78", "OWASP-A03"]
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "SQLI",
          "level": "error",
          "message": {
            "text": "SQL injection in authenticate_user(): user-supplied `username` and `password` are interpolated directly into a SQL query via f-string formatting. An attacker can supply `' OR '1'='1' --` as username to bypass authentication or exfiltrate data. Use parameterized queries: `cursor.execute(\"SELECT * FROM users WHERE username = ? AND password = ?\", (username, password))`."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "models.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 8,
                  "snippet": {
                    "text": "query = f\"SELECT * FROM users WHERE username = '{username}' AND password = '{password}'\""
                  }
                }
              }
            }
          ],
          "properties": {
            "confidence": 0.98
          }
        },
        {
          "ruleId": "IDOR",
          "level": "error",
          "message": {
            "text": "Insecure Direct Object Reference on GET /api/user/<user_id>: the endpoint retrieves any user record by integer ID without verifying the caller's identity or authorization. An attacker can enumerate all user records by iterating over sequential IDs. Implement authentication and authorization checks to ensure the caller is permitted to access the requested user's data."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "api.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 1,
                  "snippet": {
                    "text": "GET /api/user/<user_id>"
                  }
                }
              }
            }
          ],
          "properties": {
            "confidence": 0.95
          }
        },
        {
          "ruleId": "SENSITIVE-LOG",
          "level": "warning",
          "message": {
            "text": "Credentials logged in plaintext: `logger.debug(f\"Executing query: {query}\")` writes the full SQL query—including the username and password values—to logs. Remove or redact sensitive fields before logging."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "models.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 9,
                  "snippet": {
                    "text": "logger.debug(f\"Executing query: {query}\")"
                  }
                }
              }
            }
          ],
          "properties": {
            "confidence": 0.95
          }
        },
        {
          "ruleId": "INFO-DISCLOSURE",
          "level": "warning",
          "message": {
            "text": "API key exposed in authentication response: the `api_key` field (result[5]) is returned as part of the user dictionary. This leaks secrets to any caller who authenticates. Additionally, `logger.error(f\"Database error: {e}\")` may disclose internal schema or query details."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "models.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 17,
                  "snippet": {
                    "text": "'api_key': result[5]"
                  }
                }
              }
            }
          ],
          "properties": {
            "confidence": 0.90
          }
        },
        {
          "ruleId": "RCE",
          "level": "error",
          "message": {
            "text": "Arbitrary code execution via `eval(code)`: user-supplied input is passed directly to Python's eval() builtin, allowing an attacker to execute arbitrary code on the server (e.g., `__import__('os').system('rm -rf /')`). Remove eval() entirely and use a safe alternative such as ast.literal_eval() for data parsing, or a purpose-built DSL."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "api.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 1,
                  "snippet": {
                    "text": "eval(code)"
                  }
                }
              }
            }
          ],
          "properties": {
            "confidence": 0.97
          }
        },
        {
          "ruleId": "SSRF",
          "level": "error",
          "message": {
            "text": "Server-Side Request Forgery via `requests.get`: a URL from user input is fetched without validation, allowing an attacker to probe internal services (e.g., http://169.254.169.254/latest/meta-data/ for cloud metadata). Validate and allowlist target URLs before issuing outbound requests."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "api.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 1,
                  "snippet": {
                    "text": "requests.get"
                  }
                }
              }
            }
          ],
          "properties": {
            "confidence": 0.85
          }
        },
        {
          "ruleId": "CMDI",
          "level": "error",
          "message": {
            "text": "OS command injection via `subprocess.run`: user input may be passed to a shell command without sanitization, enabling arbitrary command execution. Use a fixed command with a safe argument list and avoid shell=True."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "api.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 1,
                  "snippet": {
                    "text": "subprocess.run"
                  }
                }
              }
            }
          ],
          "properties": {
            "confidence": 0.85
          }
        }
      ],
      "invocations": [
        {
          "executionSuccessful": true,
          "properties": {
            "surface_id": "SURFACE-002",
            "surface_kind": "endpoint",
            "surface_identifier": "GET /api/user/<user_id>"
          }
        }
      ],
      "artifacts": [
        {
          "location": {
            "uri": "api.py",
            "uriBaseId": "%SRCROOT%"
          }
        },
        {
          "location": {
            "uri": "models.py",
            "uriBaseId": "%SRCROOT%"
          }
        }
      ]
    }
  ]
}
