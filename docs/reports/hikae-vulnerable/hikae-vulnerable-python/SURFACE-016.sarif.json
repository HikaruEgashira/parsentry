{
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/master/Schemata/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "Parsentry",
          "version": "0.14.0",
          "informationUri": "https://github.com/HikaruEgashira/parsentry",
          "rules": [
            {
              "id": "LFI",
              "name": "LocalFileInclusion",
              "shortDescription": {
                "text": "Local File Inclusion via unvalidated 'file' parameter passed to open()"
              },
              "fullDescription": {
                "text": "The GET /lfi endpoint reads the 'file' query parameter from the request and passes it directly to Python's open() built-in without any path validation, sanitization, or allowlist check. An attacker can read arbitrary files on the server filesystem (e.g., /etc/passwd, /etc/shadow, application source code, environment files containing secrets) by supplying absolute paths or path traversal sequences (../../). This constitutes a CWE-22 (Path Traversal) / CWE-98 (Improper Control of Filename for Include) vulnerability."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/22.html",
              "properties": {
                "tags": ["security", "CWE-22", "CWE-98", "OWASP-A01:2021"]
              }
            },
            {
              "id": "INFO-DISCLOSURE",
              "name": "InformationDisclosureViaErrorMessage",
              "shortDescription": {
                "text": "Exception details leaked to user in error response"
              },
              "fullDescription": {
                "text": "When the open() call fails, the raw Python exception message is returned to the client via f-string formatting (f\"Error reading file: {e}\"). This reveals internal filesystem structure, permission details, and existence of files to an attacker, aiding further exploitation of the LFI vulnerability."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/209.html",
              "properties": {
                "tags": ["security", "CWE-209", "OWASP-A09:2021"]
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "LFI",
          "level": "error",
          "message": {
            "text": "User-controlled 'file' parameter from request.args.get(\"file\") is passed directly to open(file_path, 'r') without any path validation, allowlisting, or chroot restriction. An attacker can read arbitrary server files including /etc/passwd, application secrets, and source code."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "app.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 364,
                  "startColumn": 18,
                  "endLine": 364,
                  "endColumn": 42
                }
              }
            }
          ],
          "codeFlows": [
            {
              "threadFlows": [
                {
                  "locations": [
                    {
                      "location": {
                        "physicalLocation": {
                          "artifactLocation": {
                            "uri": "app.py",
                            "uriBaseId": "%SRCROOT%"
                          },
                          "region": {
                            "startLine": 359,
                            "startColumn": 17
                          }
                        },
                        "message": {
                          "text": "Source: user input from request.args.get(\"file\", \"\")"
                        }
                      }
                    },
                    {
                      "location": {
                        "physicalLocation": {
                          "artifactLocation": {
                            "uri": "app.py",
                            "uriBaseId": "%SRCROOT%"
                          },
                          "region": {
                            "startLine": 364,
                            "startColumn": 18
                          }
                        },
                        "message": {
                          "text": "Sink: open(file_path, 'r') — arbitrary file read with no path validation"
                        }
                      }
                    }
                  ]
                }
              ]
            }
          ],
          "properties": {
            "confidence": 0.99,
            "source": "request.args.get(\"file\", \"\")",
            "sink": "open(file_path, 'r')"
          }
        },
        {
          "ruleId": "INFO-DISCLOSURE",
          "level": "warning",
          "message": {
            "text": "Python exception details are returned directly to the client in the error message f\"Error reading file: {e}\", revealing internal filesystem paths, file existence, and permission information."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "app.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 367,
                  "startColumn": 23,
                  "endLine": 367,
                  "endColumn": 53
                }
              }
            }
          ],
          "properties": {
            "confidence": 0.95
          }
        }
      ]
    }
  ]
}
