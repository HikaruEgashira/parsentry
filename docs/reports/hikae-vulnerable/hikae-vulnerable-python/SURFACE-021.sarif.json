{
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/main/sarif-2.1/schema/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "parsentry",
          "version": "0.1.0",
          "informationUri": "https://github.com/HikaruEgashira/parsentry",
          "rules": [
            {
              "id": "SQLI",
              "name": "SQLInjection",
              "shortDescription": {
                "text": "SQL Injection via string interpolation"
              },
              "fullDescription": {
                "text": "User-controlled input is interpolated directly into a SQL query string using f-strings, enabling an attacker to inject arbitrary SQL. Parameterized queries (cursor.execute with ? placeholders) must be used instead."
              },
              "helpUri": "https://owasp.org/Top10/A03_2021-Injection/",
              "properties": {
                "tags": ["security", "injection", "sql", "CWE-89"]
              }
            },
            {
              "id": "LOG-INJECTION",
              "name": "LogInjection",
              "shortDescription": {
                "text": "Untrusted data written to audit logs without sanitization"
              },
              "fullDescription": {
                "text": "Audit log entries are constructed from user-controlled values via SQL string interpolation. An attacker can forge, corrupt, or delete audit records, undermining the integrity of forensic evidence."
              },
              "helpUri": "https://owasp.org/www-community/attacks/Log_Injection",
              "properties": {
                "tags": ["security", "injection", "logging", "CWE-117"]
              }
            },
            {
              "id": "SENSITIVE-LOG",
              "name": "SensitiveDataInLog",
              "shortDescription": {
                "text": "Sensitive data (credentials, queries) logged in plaintext"
              },
              "fullDescription": {
                "text": "Credentials, SQL queries containing passwords, or detailed error messages are written to log output, potentially exposing secrets to anyone with log access."
              },
              "helpUri": "https://owasp.org/Top10/A09_2021-Security_Logging_and_Monitoring_Failures/",
              "properties": {
                "tags": ["security", "information-disclosure", "CWE-532"]
              }
            },
            {
              "id": "HARDCODED-CREDS",
              "name": "HardcodedCredentials",
              "shortDescription": {
                "text": "Hardcoded credentials and API keys in source code"
              },
              "fullDescription": {
                "text": "Default usernames, passwords, and API keys are embedded directly in the source code, making them trivially discoverable by anyone with access to the codebase."
              },
              "helpUri": "https://owasp.org/Top10/A07_2021-Identification_and_Authentication_Failures/",
              "properties": {
                "tags": ["security", "credentials", "CWE-798"]
              }
            },
            {
              "id": "PLAINTEXT-PASS",
              "name": "PlaintextPasswordStorage",
              "shortDescription": {
                "text": "Passwords stored without hashing"
              },
              "fullDescription": {
                "text": "The users table stores passwords in plaintext. A database compromise immediately exposes every user's password. Passwords must be stored using a strong adaptive hash (bcrypt, scrypt, argon2)."
              },
              "helpUri": "https://owasp.org/Top10/A02_2021-Cryptographic_Failures/",
              "properties": {
                "tags": ["security", "cryptography", "CWE-256"]
              }
            },
            {
              "id": "DESERIALIZE",
              "name": "UnsafeDeserialization",
              "shortDescription": {
                "text": "Unsafe pickle deserialization of user-supplied data"
              },
              "fullDescription": {
                "text": "pickle.loads() is called on user-controlled input. Python pickle can execute arbitrary code during deserialization, allowing full remote code execution."
              },
              "helpUri": "https://owasp.org/Top10/A08_2021-Software_and_Data_Integrity_Failures/",
              "properties": {
                "tags": ["security", "deserialization", "rce", "CWE-502"]
              }
            },
            {
              "id": "LFI",
              "name": "LocalFileInclusion",
              "shortDescription": {
                "text": "Arbitrary file read via unvalidated file path"
              },
              "fullDescription": {
                "text": "A file path retrieved from the database (which can be attacker-controlled via SQL injection) is opened without path validation or sandboxing, enabling reading of arbitrary files such as /etc/passwd."
              },
              "helpUri": "https://owasp.org/www-project-web-security-testing-guide/latest/4-Web_Application_Security_Testing/07-Input_Validation_Testing/11.1-Testing_for_Local_File_Inclusion",
              "properties": {
                "tags": ["security", "path-traversal", "CWE-22"]
              }
            },
            {
              "id": "IDOR",
              "name": "InsecureDirectObjectReference",
              "shortDescription": {
                "text": "Missing authorization check allows access to other users' documents"
              },
              "fullDescription": {
                "text": "The document search function accepts a user_id parameter but never uses it to restrict results. Any authenticated user can access all documents regardless of ownership."
              },
              "helpUri": "https://owasp.org/Top10/A01_2021-Broken_Access_Control/",
              "properties": {
                "tags": ["security", "access-control", "CWE-639"]
              }
            },
            {
              "id": "INFO-DISCLOSURE",
              "name": "InformationDisclosure",
              "shortDescription": {
                "text": "API keys returned in authentication response"
              },
              "fullDescription": {
                "text": "The authenticate_user method returns the user's api_key in its response dictionary. API keys should not be included in authentication responses as they may be logged, cached, or exposed to unintended consumers."
              },
              "helpUri": "https://owasp.org/Top10/A01_2021-Broken_Access_Control/",
              "properties": {
                "tags": ["security", "information-disclosure", "CWE-200"]
              }
            }
          ]
        }
      },
