          "informationUri": "https://github.com/HikaruEgashira/parsentry",
          "rules": [
            {
              "id": "SSRF",
              "name": "ServerSideRequestForgery",
              "shortDescription": {
                "text": "Server-Side Request Forgery: user-controlled URL passed to HTTP client without validation"
              },
              "fullDescription": {
                "text": "The endpoint accepts an arbitrary URL from the JSON request body and passes it directly to requests.get() with no scheme allowlist (e.g., http/https only), no hostname allowlist, and no blocking of internal/private IP ranges (127.0.0.0/8, 10.0.0.0/8, 169.254.169.254, etc.). An attacker can probe internal services, access cloud metadata endpoints, or reach otherwise-firewalled resources."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/918.html",
              "properties": {
                "tags": ["security", "CWE-918", "OWASP-A10"]
              }
            },
            {
              "id": "RCE-COMMAND-INJECTION",
              "name": "CommandInjection",
              "shortDescription": {
                "text": "OS Command Injection: user-controlled input passed to subprocess.run with shell=True"
              },
              "fullDescription": {
                "text": "The /api/exec/command endpoint takes a 'command' string from the JSON request body and passes it directly to subprocess.run() with shell=True. This grants full arbitrary command execution on the host operating system with the privileges of the web server process."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/78.html",
              "properties": {
                "tags": ["security", "CWE-78", "OWASP-A03"]
              }
            },
            {
              "id": "RCE-CODE-INJECTION",
              "name": "CodeInjection",
              "shortDescription": {
                "text": "Code Injection: user-controlled input passed to eval()"
              },
              "fullDescription": {
                "text": "The /api/eval/python endpoint takes a 'code' string from the JSON request body and passes it directly to Python's eval() built-in. This allows arbitrary Python expression evaluation, enabling full code execution including OS command execution via __import__('os').system()."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/94.html",
              "properties": {
                "tags": ["security", "CWE-94", "OWASP-A03"]
              }
            }
          ]
        }
      },
