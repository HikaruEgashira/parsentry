{
  "$schema": "https://docs.oasis-open.org/sarif/sarif/v2.1.0/errata01/os/schemas/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "parsentry",
          "version": "0.1.0",
          "informationUri": "https://github.com/HikaruEgashira/parsentry",
          "rules": [
            {
              "id": "RCE-001",
              "name": "UnsafeDeserialization",
              "shortDescription": {
                "text": "Unsafe pickle deserialization of attacker-controlled input"
              },
              "fullDescription": {
                "text": "pickle.loads() is called on user-supplied preference data encoded as latin1. An attacker can craft a malicious pickle payload that executes arbitrary code upon deserialization, leading to full Remote Code Execution (RCE). This is the most critical vulnerability in the codebase."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/502.html",
              "properties": {
                "tags": ["security", "CWE-502", "OWASP-A08:2021"]
              }
            },
            {
              "id": "SQLI-001",
              "name": "SqlInjectionAuthentication",
              "shortDescription": {
                "text": "SQL injection via f-string in authentication query"
              },
              "fullDescription": {
                "text": "User-supplied username and password are interpolated directly into a SQL query using an f-string. An attacker can bypass authentication entirely (e.g., username = \"' OR '1'='1' --\") or extract arbitrary data from the database."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/89.html",
              "properties": {
                "tags": ["security", "CWE-89", "OWASP-A03:2021"]
              }
            },
            {
              "id": "SQLI-002",
              "name": "SqlInjectionUserLookup",
              "shortDescription": {
                "text": "SQL injection via f-string in user lookup by ID"
              },
              "fullDescription": {
                "text": "The user_id parameter is interpolated directly into a SQL query without parameterization or type validation. Since user_id is typed as str, an attacker can inject arbitrary SQL."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/89.html",
              "properties": {
                "tags": ["security", "CWE-89", "OWASP-A03:2021"]
              }
            },
            {
              "id": "SQLI-003",
              "name": "SqlInjectionDocumentSearch",
              "shortDescription": {
                "text": "SQL injection in LIKE clause of document search"
              },
              "fullDescription": {
                "text": "The search query parameter is interpolated directly into a SQL LIKE clause via f-string. Combined with missing authorization checks (IDOR), an attacker can read any document in the database."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/89.html",
              "properties": {
                "tags": ["security", "CWE-89", "OWASP-A03:2021"]
              }
            },
            {
              "id": "SQLI-004",
              "name": "SqlInjectionDocumentContent",
              "shortDescription": {
                "text": "SQL injection in document content retrieval"
              },
              "fullDescription": {
                "text": "The doc_id parameter is interpolated directly into a SQL query. This can be chained with the subsequent path traversal (LFI) vulnerability to read arbitrary files from the server."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/89.html",
              "properties": {
                "tags": ["security", "CWE-89", "OWASP-A03:2021"]
              }
            },
            {
              "id": "SQLI-005",
              "name": "SqlInjectionAuditLog",
              "shortDescription": {
                "text": "SQL injection in audit log insertion"
              },
              "fullDescription": {
                "text": "Multiple parameters (user_id, action, details, ip_address) are interpolated into an INSERT statement via f-string. An attacker controlling any of these values can inject arbitrary SQL, potentially escalating privileges or corrupting audit trails."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/89.html",
              "properties": {
                "tags": ["security", "CWE-89", "OWASP-A03:2021"]
              }
            },
            {
              "id": "SQLI-006",
              "name": "SqlInjectionLogRetrieval",
              "shortDescription": {
                "text": "SQL injection in audit log retrieval"
              },
              "fullDescription": {
                "text": "The user_id parameter (typed as str) is interpolated directly into a SELECT query. An attacker can extract audit logs for any user or perform UNION-based data exfiltration."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/89.html",
              "properties": {
                "tags": ["security", "CWE-89", "OWASP-A03:2021"]
              }
            },
            {
              "id": "LFI-001",
              "name": "LocalFileInclusion",
              "shortDescription": {
                "text": "Path traversal via unvalidated file_path from database"
              },
              "fullDescription": {
                "text": "A file path retrieved from the database (which can be manipulated via SQL injection) is passed directly to open() without any path validation or sandboxing. An attacker can read arbitrary files (e.g., /etc/passwd, application secrets) from the server filesystem."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/22.html",
              "properties": {
                "tags": ["security", "CWE-22", "OWASP-A01:2021"]
              }
            },
            {
              "id": "INFO-DISCLOSURE-001",
              "name": "SensitiveDataInLogs",
              "shortDescription": {
                "text": "Credentials logged in debug output"
              },
              "fullDescription": {
                "text": "The full SQL query including username and password values is logged at DEBUG level. This exposes plaintext credentials in log files, accessible to anyone with log access."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/532.html",
              "properties": {
                "tags": ["security", "CWE-532", "OWASP-A09:2021"]
              }
            },
            {
              "id": "INFO-DISCLOSURE-002",
              "name": "ApiKeyExposure",
              "shortDescription": {
                "text": "API key returned in authentication response"
              },
              "fullDescription": {
                "text": "The authenticate_user method returns the user's api_key in its response dictionary. This unnecessarily exposes sensitive credential material to the caller and any downstream consumers."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/200.html",
              "properties": {
                "tags": ["security", "CWE-200", "OWASP-A01:2021"]
              }
            },
            {
              "id": "HARDCODED-CREDS-001",
              "name": "HardcodedCredentials",
              "shortDescription": {
                "text": "Hardcoded credentials and API keys in database initialization"
              },
              "fullDescription": {
                "text": "Default user accounts with plaintext passwords ('admin123', 'guest') and API keys ('sk-1234567890abcdef') are hardcoded in the database initialization. These provide immediate unauthorized access to the application."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/798.html",
              "properties": {
                "tags": ["security", "CWE-798", "OWASP-A07:2021"]
              }
            },
            {
              "id": "IDOR-001",
              "name": "InsecureDirectObjectReference",
              "shortDescription": {
                "text": "Missing authorization check in document search"
              },
              "fullDescription": {
                "text": "The search_documents method accepts a user_id parameter but never uses it to filter results. Any authenticated user can search and access all documents regardless of ownership."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/639.html",
              "properties": {
                "tags": ["security", "CWE-639", "OWASP-A01:2021"]
              }
            }
          ]
        }
      },
