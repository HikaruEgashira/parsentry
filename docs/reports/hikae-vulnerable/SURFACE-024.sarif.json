{
  "version": "2.1.0",
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/master/Schemata/sarif-schema-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "parsentry",
          "version": "0.1.0",
          "rules": [
            {
              "id": "SQLI",
              "name": "SQLInjection",
              "shortDescription": {
                "text": "SQL Injection via string formatting"
              },
              "fullDescription": {
                "text": "User-controlled input is directly interpolated into SQL query strings without parameterization, allowing an attacker to manipulate the query structure."
              },
              "defaultConfiguration": {
                "level": "error"
              }
            },
            {
              "id": "SENSITIVE_DATA_LOGGING",
              "name": "SensitiveDataLogging",
              "shortDescription": {
                "text": "Sensitive data logged in cleartext"
              },
              "fullDescription": {
                "text": "Sensitive information such as passwords, credentials, or tokens are written to log output or stored in database tables in plaintext, risking exposure in log files, monitoring systems, or log aggregation services."
              },
              "defaultConfiguration": {
                "level": "error"
              }
            },
            {
              "id": "HARDCODED_CREDENTIALS",
              "name": "HardcodedCredentials",
              "shortDescription": {
                "text": "Hardcoded credentials in source code"
              },
              "fullDescription": {
                "text": "Credentials (usernames, passwords, API keys) are hardcoded in source code, making them visible to anyone with repository access and difficult to rotate."
              },
              "defaultConfiguration": {
                "level": "error"
              }
            },
            {
              "id": "INFO_DISCLOSURE",
              "name": "InformationDisclosure",
              "shortDescription": {
                "text": "Information disclosure via error logging"
              },
              "fullDescription": {
                "text": "Raw exception messages containing database schema details or query structure are logged, aiding attackers in crafting injection payloads."
              },
              "defaultConfiguration": {
                "level": "warning"
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "SQLI",
          "level": "error",
          "message": {
            "text": "SQL injection in AuditLogger.log_action: all four parameters (user_id, action, details, ip_address) are interpolated directly into the INSERT statement via an f-string on lines 199-202. An attacker controlling any of these values (e.g. action=\"'; DROP TABLE audit_logs;--\") can break out of the string literal context and execute arbitrary SQL, corrupting audit integrity or exfiltrating data from other tables."
          },
          "properties": {
            "confidence": 0.98
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "models.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 199,
                  "endLine": 202
                }
              },
              "logicalLocations": [
                {
                  "name": "AuditLogger.log_action",
                  "kind": "method"
                }
              ]
            }
          ]
        },
        {
          "ruleId": "SQLI",
          "level": "error",
          "message": {
            "text": "SQL injection in AuditLogger.get_user_logs: the user_id parameter (typed as str) is interpolated directly into a SELECT query on line 215 without parameterization or type validation. An attacker can supply '1 UNION SELECT sql,2,3,4,5 FROM sqlite_master--' to enumerate the database schema, or '1 OR 1=1' to dump all users' audit logs, defeating access controls."
          },
          "properties": {
            "confidence": 0.97
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "models.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 215,
                  "endLine": 215
                }
              },
              "logicalLocations": [
                {
                  "name": "AuditLogger.get_user_logs",
                  "kind": "method"
                }
              ]
            }
          ]
        },
        {
          "ruleId": "SENSITIVE_DATA_LOGGING",
          "level": "error",
          "message": {
            "text": "The audit_logs table stores the 'details' field without any sanitization or redaction. Callers can pass passwords, tokens, or PII as details strings which are then persisted in cleartext. Additionally, UserModel.authenticate_user logs the full SQL query including the plaintext password at DEBUG level on line 86 (logger.debug with the query containing the password). This data could propagate into audit records, creating a credential harvesting target if the audit_logs table is compromised via the SQLI vulnerabilities."
          },
          "properties": {
            "confidence": 0.95
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "models.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 86,
                  "endLine": 86
                }
              },
              "logicalLocations": [
                {
                  "name": "UserModel.authenticate_user",
                  "kind": "method"
                }
              ]
            },
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "models.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 196,
                  "endLine": 210
                }
              },
              "logicalLocations": [
                {
                  "name": "AuditLogger.log_action",
                  "kind": "method"
                }
              ]
            }
          ]
        },
        {
          "ruleId": "HARDCODED_CREDENTIALS",
          "level": "error",
          "message": {
            "text": "Default admin and guest accounts with hardcoded plaintext passwords ('admin123', 'guest') and hardcoded API keys ('sk-1234567890abcdef', 'pk-0987654321fedcba') are inserted during database initialization on lines 60-69. These credentials are stored in the users table in cleartext and are known to anyone with source access, providing immediate unauthorized access to the application."
          },
          "properties": {
            "confidence": 0.99
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "models.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 60,
                  "endLine": 69
                }
              },
              "logicalLocations": [
                {
                  "name": "DatabaseManager.init_database",
                  "kind": "method"
                }
              ]
            }
          ]
        },
        {
          "ruleId": "INFO_DISCLOSURE",
          "level": "warning",
          "message": {
            "text": "Error handlers in AuditLogger.log_action (line 208) and AuditLogger.get_user_logs (line 229) log raw exception messages that may reveal database schema details, table names, column names, and internal query structure. This information aids attackers in refining SQL injection payloads against the identified SQLI vulnerabilities in the same methods."
          },
          "properties": {
            "confidence": 0.80
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "models.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 208,
                  "endLine": 209
                }
              },
              "logicalLocations": [
                {
                  "name": "AuditLogger.log_action",
                  "kind": "method"
                }
              ]
            },
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "models.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 228,
                  "endLine": 229
                }
              },
              "logicalLocations": [
                {
                  "name": "AuditLogger.get_user_logs",
                  "kind": "method"
                }
              ]
            }
          ]
        }
      ],
      "artifacts": [
        {
          "location": {
            "uri": "models.py",
            "uriBaseId": "%SRCROOT%"
          },
          "description": {
            "text": "Database models for the vulnerable application"
          }
        }
      ]
    }
  ]
}