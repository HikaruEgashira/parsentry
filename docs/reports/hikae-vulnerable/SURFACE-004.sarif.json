{
  "version": "2.1.0",
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/master/Schemata/sarif-schema-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "parsentry",
          "version": "0.1.0",
          "rules": [
            {
              "id": "RCE",
              "name": "RemoteCodeExecution",
              "shortDescription": {
                "text": "OS Command Injection via unsanitized user input"
              },
              "fullDescription": {
                "text": "User-controlled input is passed directly to os.popen() or os.system() without sanitization, allowing arbitrary OS command execution."
              },
              "help": {
                "text": "Use subprocess with a list of arguments (never shell=True) and validate/allowlist inputs. Never interpolate user input into shell command strings."
              },
              "properties": {
                "tags": ["security", "injection", "CWE-78"]
              }
            },
            {
              "id": "PATH_INJECTION",
              "name": "PathInjection",
              "shortDescription": {
                "text": "Unsanitized user input used in file path construction"
              },
              "fullDescription": {
                "text": "User-controlled hostname parameter is embedded in a file path string, enabling path traversal or unintended file creation."
              },
              "help": {
                "text": "Sanitize filenames with a strict allowlist (alphanumeric only) before using in path construction. Use os.path.basename() and validate against a safe base directory."
              },
              "properties": {
                "tags": ["security", "path-traversal", "CWE-22"]
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "RCE",
          "level": "error",
          "message": {
            "text": "os.popen() called with unsanitized 'count' and 'hostname' query parameters interpolated directly into a shell command string via f-string. An attacker can inject arbitrary shell commands through either parameter, e.g. hostname='; cat /etc/passwd #' or count='1; id'. Both parameters reach the sink without any validation or escaping."
          },
          "properties": {
            "confidence": 0.99
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "app.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 210,
                  "startColumn": 19,
                  "snippet": {
                    "text": "output1 = os.popen(f\"ping -c {count} {hostname}\").read()"
                  }
                }
              },
              "logicalLocations": [
                {
                  "name": "command_injection",
                  "kind": "function"
                }
              ]
            }
          ],
          "fingerprints": {
            "primaryLocationLineHash": "os.popen-cmdi-count-hostname"
          }
        },
        {
          "ruleId": "RCE",
          "level": "error",
          "message": {
            "text": "os.system() called with unsanitized 'hostname' query parameter interpolated directly into a shell command string with output redirection. An attacker can inject arbitrary shell commands via the hostname parameter, e.g. hostname='localhost; rm -rf /'. The os.system() call spawns a full shell, making exploitation trivial."
          },
          "properties": {
            "confidence": 0.99
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "app.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 214,
                  "startColumn": 9,
                  "snippet": {
                    "text": "os.system(f\"ping -c 1 {hostname} > {temp_file}\")"
                  }
                }
              },
              "logicalLocations": [
                {
                  "name": "command_injection",
                  "kind": "function"
                }
              ]
            }
          ],
          "fingerprints": {
            "primaryLocationLineHash": "os.system-cmdi-hostname"
          }
        },
        {
          "ruleId": "RCE",
          "level": "error",
          "message": {
            "text": "The 'count' query parameter is accepted as a string with no numeric validation and interpolated into the os.popen() shell command. This is an independent injection vector from 'hostname' — an attacker can pass count='1; whoami' to execute arbitrary commands even if hostname is hardcoded or filtered."
          },
          "properties": {
            "confidence": 0.97
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "app.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 207,
                  "startColumn": 5,
                  "snippet": {
                    "text": "count = request.args.get(\"count\", \"1\")"
                  }
                }
              },
              "logicalLocations": [
                {
                  "name": "command_injection",
                  "kind": "function"
                }
              ]
            }
          ],
          "fingerprints": {
            "primaryLocationLineHash": "no-validation-count-param"
          }
        },
        {
          "ruleId": "PATH_INJECTION",
          "level": "warning",
          "message": {
            "text": "The 'hostname' query parameter is embedded in a temporary file path '/tmp/ping_result_{hostname}.txt' without sanitization. An attacker can include path separators or traversal sequences (e.g. hostname='../../etc/cron.d/evil') to write ping output to arbitrary filesystem locations, potentially enabling further exploitation."
          },
          "properties": {
            "confidence": 0.92
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "app.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 213,
                  "startColumn": 9,
                  "snippet": {
                    "text": "temp_file = f\"/tmp/ping_result_{hostname}.txt\""
                  }
                }
              },
              "logicalLocations": [
                {
                  "name": "command_injection",
                  "kind": "function"
                }
              ]
            }
          ],
          "fingerprints": {
            "primaryLocationLineHash": "path-injection-cmdi-hostname-tempfile"
          }
        }
      ],
      "artifacts": [
        {
          "location": {
            "uri": "app.py",
            "uriBaseId": "%SRCROOT%"
          },
          "description": {
            "text": "Flask application entry point containing the /cmdi endpoint with os.popen() and os.system() command injection vulnerabilities"
          }
        }
      ]
    }
  ]
}
