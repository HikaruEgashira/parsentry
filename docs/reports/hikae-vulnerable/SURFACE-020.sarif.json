{
  "$schema": "https://docs.oasis-open.org/sarif/sarif/v2.1.0/errata01/os/schemas/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "parsentry",
          "version": "0.1.0",
          "rules": [
            {
              "id": "SQLI",
              "name": "SQLInjection",
              "shortDescription": {
                "text": "SQL Injection via unsanitized user input in query construction"
              },
              "defaultConfiguration": {
                "level": "error"
              }
            },
            {
              "id": "IDOR",
              "name": "InsecureDirectObjectReference",
              "shortDescription": {
                "text": "Missing authorization check allows access to other users' resources"
              },
              "defaultConfiguration": {
                "level": "error"
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "SQLI",
          "level": "error",
          "message": {
            "text": "SQL injection in document search LIKE clause. The 'q' query parameter is passed unsanitized into an f-string SQL query: `f\"SELECT * FROM documents WHERE title LIKE '%{query}%'\"` in DocumentModel.search_documents(). An attacker can break out of the LIKE pattern with input such as `%' UNION SELECT id,username,password,role,api_key FROM users--` to exfiltrate the entire users table including plaintext passwords and API keys. No parameterized query or input sanitization is used."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "models.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 131,
                  "startColumn": 15,
                  "endLine": 131,
                  "endColumn": 65
                }
              },
              "logicalLocations": [
                {
                  "name": "DocumentModel.search_documents",
                  "kind": "method"
                }
              ]
            }
          ],
          "relatedLocations": [
            {
              "id": 1,
              "message": {
                "text": "Tainted input: 'q' parameter read from query string without validation and forwarded to vulnerable SQL method"
              },
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "api.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 82,
                  "startColumn": 5,
                  "endLine": 88,
                  "endColumn": 51
                }
              }
            }
          ],
          "properties": {
            "confidence": 1.0,
            "surface_id": "SURFACE-020",
            "cwe": [
              "CWE-89"
            ],
            "owasp": [
              "A03:2021-Injection"
            ]
          }
        },
        {
          "ruleId": "IDOR",
          "level": "error",
          "message": {
            "text": "Insecure Direct Object Reference in document search. The endpoint accepts a caller-supplied 'user_id' from the query string (defaulting to 1) with no authentication or authorization check. Worse, DocumentModel.search_documents() accepts user_id as a parameter but never uses it in the SQL query \u2014 the query `SELECT * FROM documents WHERE title LIKE '%{query}%'` has no owner_id filter. All documents in the database are returned regardless of the caller's identity or the user_id supplied. Any unauthenticated user can search and retrieve all documents belonging to any user."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "api.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 82,
                  "startColumn": 1,
                  "endLine": 88,
                  "endColumn": 42
                }
              },
              "logicalLocations": [
                {
                  "name": "search_documents",
                  "kind": "function"
                }
              ]
            }
          ],
          "relatedLocations": [
            {
              "id": 2,
              "message": {
                "text": "SQL query in search_documents does not filter by owner_id; the user_id parameter is accepted but ignored, providing no access control"
              },
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "models.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 124,
                  "startColumn": 5,
                  "endLine": 150,
                  "endColumn": 22
                }
              }
            }
          ],
          "properties": {
            "confidence": 1.0,
            "surface_id": "SURFACE-020",
            "cwe": [
              "CWE-639"
            ],
            "owasp": [
              "A01:2021-Broken Access Control"
            ]
          }
        }
      ],
      "artifacts": [
        {
          "location": {
            "uri": "api.py",
            "uriBaseId": "%SRCROOT%"
          },
          "description": {
            "text": "Flask API blueprint defining the /api/documents/search endpoint"
          }
        },
        {
          "location": {
            "uri": "models.py",
            "uriBaseId": "%SRCROOT%"
          },
          "description": {
            "text": "Database model layer containing DocumentModel.search_documents with vulnerable SQL"
          }
        }
      ]
    }
  ]
}