      "tool": {
        "driver": {
          "name": "parsentry",
          "version": "0.1.0",
          "informationUri": "https://github.com/HikaruEgashira/parsentry",
          "rules": [
            {
              "id": "XSS-HTML-BODY",
              "name": "ReflectedXSSInHTMLBody",
              "shortDescription": {
                "text": "Reflected XSS via f-string interpolation in HTML body context"
              },
              "fullDescription": {
                "text": "User-controlled input from query parameter 'name' is interpolated directly into an HTML body context using an f-string, bypassing Jinja2 auto-escaping. An attacker can inject arbitrary HTML and JavaScript via the 'name' parameter."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/79.html",
              "properties": {
                "tags": [
                  "security",
                  "CWE-79",
                  "xss",
                  "reflected"
                ]
              }
            },
            {
              "id": "XSS-HTML-ATTR",
              "name": "ReflectedXSSInHTMLAttribute",
              "shortDescription": {
                "text": "Reflected XSS via f-string interpolation in HTML attribute context"
              },
              "fullDescription": {
                "text": "User-controlled input from query parameter 'name' is interpolated into an HTML attribute value using an f-string without escaping. An attacker can break out of the attribute with a double-quote and inject event handlers or new attributes."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/79.html",
              "properties": {
                "tags": [
                  "security",
                  "CWE-79",
                  "xss",
                  "reflected",
                  "attribute-context"
                ]
              }
            },
            {
              "id": "XSS-JS-CONTEXT",
              "name": "ReflectedXSSInJavaScriptContext",
              "shortDescription": {
                "text": "Reflected XSS via f-string interpolation in JavaScript string literal"
              },
              "fullDescription": {
                "text": "User-controlled inputs from query parameters 'name' and 'comment' are interpolated into JavaScript string literals using f-strings. An attacker can break out of the string with a single-quote and execute arbitrary JavaScript. This is particularly dangerous as it allows direct code execution without requiring HTML parsing."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/79.html",
              "properties": {
                "tags": [
                  "security",
                  "CWE-79",
                  "xss",
                  "reflected",
                  "javascript-context"
                ]
              }
            },
            {
              "id": "XSS-CSS-CONTEXT",
              "name": "ReflectedXSSInCSSContext",
              "shortDescription": {
                "text": "Reflected XSS via f-string interpolation in CSS property value"
              },
              "fullDescription": {
                "text": "User-controlled input from query parameter 'comment' is interpolated into a CSS property value using an f-string. An attacker can inject CSS expressions or use CSS-based exfiltration techniques. In older browsers, this can lead to JavaScript execution via expression() or url() with javascript: scheme."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/79.html",
              "properties": {
                "tags": [
                  "security",
                  "CWE-79",
                  "xss",
                  "reflected",
                  "css-context"
                ]
              }
            },
            {
              "id": "XSS-STORED-DISPLAY",
              "name": "ReflectedXSSInCommentDisplay",
              "shortDescription": {
                "text": "Reflected XSS via unescaped comment display in HTML body"
              },
              "fullDescription": {
                "text": "User-controlled input from query parameter 'comment' is rendered directly in an HTML div element via f-string interpolation. The comment is displayed as 'Stored Comments' without any sanitization, enabling reflected XSS."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/79.html",
              "properties": {
                "tags": [
                  "security",
                  "CWE-79",
                  "xss",
                  "reflected"
                ]
              }
            },
            {
              "id": "XSS-ATTR-FORM",
              "name": "ReflectedXSSInFormInputAttributes",
              "shortDescription": {
                "text": "Reflected XSS via f-string in form input value attributes"
              },
              "fullDescription": {
                "text": "Both 'name' and 'comment' query parameters are interpolated into form input value attributes via f-strings. An attacker can break out of the attribute context and inject event handlers such as onfocus or onmouseover."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/79.html",
              "properties": {
                "tags": [
                  "security",
                  "CWE-79",
                  "xss",
                  "reflected",
                  "attribute-context"
                ]
              }
            }
          ]
        }
