              "name": "CrossSiteScripting",
              "shortDescription": {
                "text": "Cross-Site Scripting (XSS)"
              },
              "fullDescription": {
                "text": "User-controlled input is reflected into HTML output without sanitization, enabling injection of arbitrary script content."
              },
              "helpUri": "https://owasp.org/www-community/attacks/xss/",
              "properties": {
                "tags": ["security", "correctness"],
                "cwe": ["CWE-79"]
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "XSS",
          "level": "error",
          "message": {
            "text": "Reflected XSS in HTML context: the `name` parameter from request.args is interpolated via Python f-string directly into HTML at line 286 (`Hello, {name}!`). Jinja2 autoescaping is entirely bypassed because the f-string builds the raw HTML string before render_template_string() processes it, so any HTML/script payload in `name` is rendered verbatim in the DOM."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "app.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
