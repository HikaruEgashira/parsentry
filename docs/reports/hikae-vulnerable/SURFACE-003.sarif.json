            "attack_vector": "GET /xss?comment=<img+src=x+onerror=alert(1)>",
            "context": "HTML body"
          }
        },
        {
          "ruleId": "XSS",
          "level": "error",
          "message": {
            "text": "Root cause: the entire HTML template for GET /xss is constructed as a Python f-string (lines 282-313) using unsanitized request.args parameters `name` and `comment`. The resulting string is passed to render_template_string(), but by that point the raw user input is already embedded verbatim in HTML. Jinja2 autoescaping never sees the user data because it was concatenated by the f-string before template rendering. Fix: pass user inputs as Jinja2 template variables via keyword arguments to render_template_string() and use {{ name }} / {{ comment }} placeholders instead of f-string interpolation."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "app.py",
                  "uriBaseId": "%SRCROOT%"
                },
