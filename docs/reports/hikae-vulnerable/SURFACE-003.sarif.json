                {
                  "name": "xss",
                  "kind": "function"
                }
              ]
            }
          ],
          "properties": {
            "confidence": 1.0,
            "attack_vector": "GET /xss?name=<script>alert(1)</script>",
            "context": "HTML body"
          }
        },
        {
          "ruleId": "XSS",
          "level": "error",
          "message": {
            "text": "Reflected XSS in HTML attribute context: the `name` parameter is interpolated directly into an HTML attribute value at line 289 (`value=\"{name}\"`). An attacker can break out of the attribute with a double-quote and inject event handlers, e.g. `\" onfocus=alert(1) autofocus x=\"`."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
