{
  "version": "2.1.0",
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/master/Schemata/sarif-schema-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "parsentry",
          "version": "0.1.0",
          "rules": [
            {
              "id": "LFI",
              "name": "LocalFileInclusion",
              "shortDescription": {
                "text": "Local File Inclusion via arbitrary file read"
              },
              "fullDescription": {
                "text": "User-controlled input is passed directly to a file open call without any path validation or sanitization, allowing an attacker to read arbitrary files from the filesystem including sensitive files such as /etc/passwd, /etc/shadow, or application secrets."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/22.html",
              "properties": {
                "tags": [
                  "security",
                  "CWE-22",
                  "OWASP-A01"
                ]
              }
            },
            {
              "id": "PATH_TRAVERSAL",
              "name": "PathTraversal",
              "shortDescription": {
                "text": "Path traversal enabling directory escape"
              },
              "fullDescription": {
                "text": "The absence of path normalization and base-directory restriction allows sequences such as ../../ to escape the intended directory scope."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/23.html",
              "properties": {
                "tags": [
                  "security",
                  "CWE-23",
                  "OWASP-A01"
                ]
              }
            },
            {
              "id": "INFO_DISCLOSURE",
              "name": "InformationDisclosure",
              "shortDescription": {
                "text": "Error message leaks filesystem structure"
              },
              "fullDescription": {
                "text": "Exceptions from failed file reads are returned verbatim to the client, disclosing internal path structures and operating-system details that aid further attacks."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/209.html",
              "properties": {
                "tags": [
                  "security",
                  "CWE-209"
                ]
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "LFI",
          "level": "error",
          "message": {
            "text": "The `file` query parameter is passed without validation directly to `open(file_path, 'r')`. An attacker can supply any absolute path (e.g. /etc/passwd, /etc/shadow, ~/.ssh/id_rsa) or a relative path to read arbitrary files readable by the process user. The source is `request.args.get(\"file\", \"\")` and the sink is `open(file_path, 'r')` with no intervening sanitization."
          },
          "properties": {
            "confidence": 1.0,
            "severity": "critical",
            "attack_vector": "GET /lfi?file=/etc/passwd",
            "cwe": [
              "CWE-22"
            ]
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "app.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 248,
                  "endLine": 272,
                  "startColumn": 1
                }
              },
              "logicalLocations": [
                {
                  "name": "local_file_inclusion",
                  "kind": "function"
                }
              ]
            }
          ],
          "fixes": [
            {
              "description": {
                "text": "Validate and restrict file_path to a safe base directory using os.path.realpath and a whitelist/allowlist check before opening."
              }
            }
          ]
        },
        {
          "ruleId": "PATH_TRAVERSAL",
          "level": "error",
          "message": {
            "text": "Because no path canonicalization is applied, sequences like ../../etc/passwd are accepted. The application UI explicitly advertises this attack vector ('Try: /etc/passwd, /etc/hosts, ../../etc/passwd'), confirming the vulnerability is intentional in this test app but would be critical in production."
          },
          "properties": {
            "confidence": 1.0,
            "severity": "critical",
            "attack_vector": "GET /lfi?file=../../etc/passwd",
            "cwe": [
              "CWE-23"
            ]
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "app.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 253,
                  "endLine": 254,
                  "startColumn": 13
                }
              },
              "logicalLocations": [
                {
                  "name": "local_file_inclusion",
                  "kind": "function"
                }
              ]
            }
          ],
          "fixes": [
            {
              "description": {
                "text": "Use os.path.realpath() to resolve the canonical path and verify it starts with the permitted base directory before any file I/O."
              }
            }
          ]
        },
        {
          "ruleId": "INFO_DISCLOSURE",
          "level": "warning",
          "message": {
            "text": "The exception message from a failed `open()` call (e.g. 'No such file or directory: /secret') is captured and rendered into the HTML response via f-string interpolation, leaking filesystem path information to unauthenticated users."
          },
          "properties": {
            "confidence": 0.95,
            "severity": "medium",
            "cwe": [
              "CWE-209"
            ]
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "app.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 255,
                  "endLine": 256,
                  "startColumn": 9
                }
              },
              "logicalLocations": [
                {
                  "name": "local_file_inclusion",
                  "kind": "function"
                }
              ]
            }
          ],
          "fixes": [
            {
              "description": {
                "text": "Replace the raw exception message with a generic error string. Log the exception server-side only."
              }
            }
          ]
        }
      ],
      "artifacts": [
        {
          "location": {
            "uri": "app.py",
            "uriBaseId": "%SRCROOT%"
          },
          "length": 462,
          "mimeType": "text/x-python"
        }
      ]
    }
  ]
}