{
  "version": "2.1.0",
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/master/Schemata/sarif-schema-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "parsentry",
          "version": "0.1.0",
          "rules": [
            {
              "id": "PATH_TRAVERSAL",
              "name": "PathTraversal",
              "shortDescription": {
                "text": "Path traversal via unsanitized filename"
              },
              "fullDescription": {
                "text": "User-controlled filename is passed directly to os.path.join without sanitization, allowing directory traversal sequences (e.g. '../') to write files outside the intended upload directory."
              },
              "helpUri": "https://owasp.org/www-community/attacks/Path_Traversal",
              "defaultConfiguration": {
                "level": "error"
              }
            },
            {
              "id": "UNRESTRICTED_FILE_UPLOAD",
              "name": "UnrestrictedFileUpload",
              "shortDescription": {
                "text": "Unrestricted file upload with no type or content validation"
              },
              "fullDescription": {
                "text": "The endpoint accepts and saves any file without validating its MIME type, extension, or content. This allows an attacker to upload executable scripts (e.g. PHP webshells, Python scripts) that may be executed by the server."
              },
              "helpUri": "https://owasp.org/www-community/vulnerabilities/Unrestricted_File_Upload",
              "defaultConfiguration": {
                "level": "error"
              }
            },
            {
              "id": "INFO_DISCLOSURE",
              "name": "InformationDisclosure",
              "shortDescription": {
                "text": "Absolute file path returned to caller"
              },
              "fullDescription": {
                "text": "The response includes the full server-side absolute path of the saved file, disclosing internal directory structure to the attacker."
              },
              "helpUri": "https://owasp.org/www-project-web-security-testing-guide/",
              "defaultConfiguration": {
                "level": "warning"
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "PATH_TRAVERSAL",
          "level": "error",
          "message": {
            "text": "file.filename is used directly in os.path.join without sanitization. An attacker can supply a filename like '../../etc/cron.d/shell' to write arbitrary files outside /tmp/uploads, achieving arbitrary file write and potentially remote code execution."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "api.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 186,
                  "endLine": 187
                }
              },
              "logicalLocations": [
                {
                  "name": "upload_file",
                  "kind": "function"
                }
              ]
            }
          ],
          "properties": {
            "confidence": 0.98
          }
        },
        {
          "ruleId": "UNRESTRICTED_FILE_UPLOAD",
          "level": "error",
          "message": {
            "text": "No file type, extension, or magic-byte validation is performed before saving the uploaded file. An attacker can upload a malicious script (e.g. a Python/PHP webshell) that, combined with the path traversal, can be placed in an executable location and triggered remotely."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "api.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 170,
                  "endLine": 193
                }
              },
              "logicalLocations": [
                {
                  "name": "upload_file",
                  "kind": "function"
                }
              ]
            }
          ],
          "properties": {
            "confidence": 0.97
          }
        },
        {
          "ruleId": "INFO_DISCLOSURE",
          "level": "warning",
          "message": {
            "text": "The JSON response at line 221-224 returns both 'path' (absolute server path) and 'filename' (attacker-controlled) to the caller. This reveals internal filesystem layout and confirms successful path traversal write locations to an attacker."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "api.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 189,
                  "endLine": 193
                }
              },
              "logicalLocations": [
                {
                  "name": "upload_file",
                  "kind": "function"
                }
              ]
            }
          ],
          "properties": {
            "confidence": 0.90
          }
        }
      ],
      "artifacts": [
        {
          "location": {
            "uri": "api.py",
            "uriBaseId": "%SRCROOT%"
          },
          "description": {
            "text": "Flask API blueprint containing the vulnerable POST /api/file/upload endpoint"
          }
        }
      ]
    }
  ]
}
