{
  "version": "2.1.0",
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/master/Schemata/sarif-schema-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "parsentry",
          "version": "0.1.0",
          "rules": [
            {
              "id": "SQLI",
              "name": "SQLInjection",
              "shortDescription": {
                "text": "SQL Injection"
              },
              "fullDescription": {
                "text": "User-controlled input is directly interpolated into SQL queries without parameterization, enabling authentication bypass and data exfiltration."
              },
              "defaultConfiguration": {
                "level": "error"
              }
            },
            {
              "id": "HARDCODED_SECRET",
              "name": "HardcodedSecret",
              "shortDescription": {
                "text": "Hardcoded Secret or Credential"
              },
              "fullDescription": {
                "text": "Secrets such as JWT signing keys and API keys are hardcoded in source code, making them trivially discoverable."
              },
              "defaultConfiguration": {
                "level": "error"
              }
            },
            {
              "id": "SENSITIVE_DATA_LOGGING",
              "name": "SensitiveDataLogging",
              "shortDescription": {
                "text": "Sensitive Data Written to Logs"
              },
              "fullDescription": {
                "text": "Passwords and other credentials are written to audit logs or debug logs in plaintext, violating confidentiality."
              },
              "defaultConfiguration": {
                "level": "error"
              }
            },
            {
              "id": "API_KEY_EXPOSURE",
              "name": "APIKeyExposure",
              "shortDescription": {
                "text": "API Key Returned in HTTP Response"
              },
              "fullDescription": {
                "text": "Internal API keys are included in JSON responses, exposing them to any client that receives the response."
              },
              "defaultConfiguration": {
                "level": "error"
              }
            },
            {
              "id": "WEAK_JWT",
              "name": "WeakJWT",
              "shortDescription": {
                "text": "Weak JWT Configuration"
              },
              "fullDescription": {
                "text": "JWT tokens are signed with a hardcoded, weak secret using HS256. Any party with the secret can forge tokens."
              },
              "defaultConfiguration": {
                "level": "error"
              }
            },
            {
              "id": "INFO_DISCLOSURE",
              "name": "InformationDisclosure",
              "shortDescription": {
                "text": "Information Disclosure via Error Messages"
              },
              "fullDescription": {
                "text": "Internal exception messages are returned directly in HTTP error responses, leaking implementation details."
              },
              "defaultConfiguration": {
                "level": "warning"
              }
            },
            {
              "id": "PLAINTEXT_PASSWORD_STORAGE",
              "name": "PlaintextPasswordStorage",
              "shortDescription": {
                "text": "Passwords Stored in Plaintext"
              },
              "fullDescription": {
                "text": "User passwords are stored as plaintext strings in the database without hashing, enabling full credential compromise on DB breach."
              },
              "defaultConfiguration": {
                "level": "error"
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "SQLI",
          "level": "error",
          "message": {
            "text": "SQL injection in authenticate_user(): username and password are interpolated directly into the query string via f-string: `f\"SELECT * FROM users WHERE username = '{username}' AND password = '{password}'\"`. An attacker can supply `' OR '1'='1' --` as the username to bypass authentication entirely."
          },
          "properties": {
            "confidence": 1.0
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "models.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 76,
                  "startColumn": 9,
                  "endLine": 76,
                  "endColumn": 90
                }
              },
              "logicalLocations": [
                {
                  "name": "UserModel.authenticate_user",
                  "kind": "function"
                }
              ]
            }
          ]
        },
        {
          "ruleId": "SQLI",
          "level": "error",
          "message": {
            "text": "Second-order SQL injection in AuditLogger.log_action(): the details parameter (which includes the raw user password from api.py line 52) and ip_address are interpolated into an INSERT statement via f-string without parameterization. A crafted password containing SQL metacharacters triggers injection when the audit log is written."
          },
          "properties": {
            "confidence": 1.0
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "models.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 230,
                  "startColumn": 9,
                  "endLine": 233,
                  "endColumn": 11
                }
              },
              "logicalLocations": [
                {
                  "name": "AuditLogger.log_action",
                  "kind": "function"
                }
              ]
            }
          ]
        },
        {
          "ruleId": "HARDCODED_SECRET",
          "level": "error",
          "message": {
            "text": "JWT signing secret JWT_SECRET = \"super_secret_key_123\" is hardcoded at module level in api.py. Any developer or leaked source code enables arbitrary JWT token forgery, allowing impersonation of any user or role."
          },
          "properties": {
            "confidence": 1.0
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "api.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 22,
                  "startColumn": 1,
                  "endLine": 22,
                  "endColumn": 40
                }
              },
              "logicalLocations": [
                {
                  "name": "module-level",
                  "kind": "module"
                }
              ]
            }
          ]
        },
        {
          "ruleId": "HARDCODED_SECRET",
          "level": "error",
          "message": {
            "text": "API keys are hardcoded in the API_KEYS dictionary (api.py lines 23-26) and also seeded into the database in models.py. Values 'sk-1234567890abcdef' (admin) and 'pk-0987654321fedcba' (guest) are in plaintext source."
          },
          "properties": {
            "confidence": 1.0
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "api.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 23,
                  "startColumn": 1,
                  "endLine": 26,
                  "endColumn": 2
                }
              },
              "logicalLocations": [
                {
                  "name": "module-level",
                  "kind": "module"
                }
              ]
            }
          ]
        },
        {
          "ruleId": "SENSITIVE_DATA_LOGGING",
          "level": "error",
          "message": {
            "text": "Plaintext password is persisted to the audit_logs table via audit_logger.log_action() with the message f\"User {username} logged in with password {password}\". Anyone with database read access recovers all user passwords from the audit trail."
          },
          "properties": {
            "confidence": 1.0
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "api.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 50,
                  "startColumn": 13,
                  "endLine": 55,
                  "endColumn": 14
                }
              },
              "logicalLocations": [
                {
                  "name": "api_login",
                  "kind": "function"
                }
              ]
            }
          ]
        },
        {
          "ruleId": "SENSITIVE_DATA_LOGGING",
          "level": "error",
          "message": {
            "text": "The full SQL query including raw username and password is written to the debug log via logger.debug() in authenticate_user(). Debug logs are often forwarded to centralized log systems, persisting credentials outside the application boundary."
          },
          "properties": {
            "confidence": 1.0
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "models.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 77,
                  "startColumn": 9,
                  "endLine": 77,
                  "endColumn": 60
                }
              },
              "logicalLocations": [
                {
                  "name": "UserModel.authenticate_user",
                  "kind": "function"
                }
              ]
            }
          ]
        },
        {
          "ruleId": "API_KEY_EXPOSURE",
          "level": "error",
          "message": {
            "text": "The login response JSON includes 'api_key': user['api_key'], returning the user's internal API key to the client on every successful authentication. Combined with the SQL injection in authenticate_user(), an attacker who bypasses auth also obtains the admin API key."
          },
          "properties": {
            "confidence": 1.0
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "api.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 58,
                  "startColumn": 17,
                  "endLine": 58,
                  "endColumn": 51
                }
              },
              "logicalLocations": [
                {
                  "name": "api_login",
                  "kind": "function"
                }
              ]
            }
          ]
        },
        {
          "ruleId": "WEAK_JWT",
          "level": "error",
          "message": {
            "text": "JWT is signed with HS256 using a hardcoded 22-character secret 'super_secret_key_123'. HS256 requires a cryptographically random secret of at least 256 bits. The token embeds role claims (including 'admin') without server-side re-validation, so a forged token grants full privilege escalation."
          },
          "properties": {
            "confidence": 1.0
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "api.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 43,
                  "startColumn": 21,
                  "endLine": 47,
                  "endColumn": 51
                }
              },
              "logicalLocations": [
                {
                  "name": "api_login",
                  "kind": "function"
                }
              ]
            }
          ]
        },
        {
          "ruleId": "INFO_DISCLOSURE",
          "level": "warning",
          "message": {
            "text": "The except block in api_login() returns f'Authentication failed: {str(e)}' in the HTTP 500 response body. Internal exception details (database errors, file paths, library versions) are exposed to the client, aiding reconnaissance."
          },
          "properties": {
            "confidence": 0.95
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "api.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 64,
                  "startColumn": 9,
                  "endLine": 64,
                  "endColumn": 75
                }
              },
              "logicalLocations": [
                {
                  "name": "api_login",
                  "kind": "function"
                }
              ]
            }
          ]
        },
        {
          "ruleId": "PLAINTEXT_PASSWORD_STORAGE",
          "level": "error",
          "message": {
            "text": "Passwords are stored as plaintext in the users table. The schema defines 'password TEXT NOT NULL' with no hashing, and seed data inserts raw strings ('admin123', 'guest'). authenticate_user() compares raw input against these plaintext values. A database breach yields all credentials immediately."
          },
          "properties": {
            "confidence": 1.0
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "models.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 27,
                  "startColumn": 9,
                  "endLine": 38,
                  "endColumn": 12
                }
              },
              "logicalLocations": [
                {
                  "name": "DatabaseManager.init_database",
                  "kind": "function"
                }
              ]
            }
          ]
        }
      ],
      "artifacts": [
        {
          "location": {
            "uri": "api.py",
            "uriBaseId": "%SRCROOT%"
          }
        },
        {
          "location": {
            "uri": "models.py",
            "uriBaseId": "%SRCROOT%"
          }
        }
      ]
    }
  ]
}