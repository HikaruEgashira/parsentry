{
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/main/sarif-2.1/schema/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "parsentry",
          "version": "0.1.0",
          "informationUri": "https://github.com/HikaruEgashira/parsentry",
          "rules": [
            {
              "id": "SQLI",
              "name": "SQLInjection",
              "shortDescription": {
                "text": "SQL Injection via string formatting in authentication query"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/89.html",
              "properties": {
                "tags": ["security", "CWE-89"]
              }
            },
            {
              "id": "SENSITIVE-LOG",
              "name": "SensitiveDataLogging",
              "shortDescription": {
                "text": "Plaintext password logged in authentication flow"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/532.html",
              "properties": {
                "tags": ["security", "CWE-532"]
              }
            },
            {
              "id": "WEAK-CRYPTO",
              "name": "WeakCryptography",
              "shortDescription": {
                "text": "Predictable session token generated with MD5"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/328.html",
              "properties": {
                "tags": ["security", "CWE-328"]
              }
            },
            {
              "id": "INFO-DISCLOSURE",
              "name": "InformationDisclosure",
              "shortDescription": {
                "text": "Username disclosed in authentication error message"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/209.html",
              "properties": {
                "tags": ["security", "CWE-209"]
              }
            },
            {
              "id": "HARDCODED-SECRET",
              "name": "HardcodedSecret",
              "shortDescription": {
                "text": "Hardcoded Flask secret key used for session signing"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/798.html",
              "properties": {
                "tags": ["security", "CWE-798"]
              }
            },
            {
              "id": "SESSION-MISCONFIG",
              "name": "SessionMisconfiguration",
              "shortDescription": {
                "text": "Session cookies lack Secure and HttpOnly flags"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/614.html",
              "properties": {
                "tags": ["security", "CWE-614"]
              }
            },
            {
              "id": "SENSITIVE-EXPOSURE",
              "name": "SensitiveDataExposure",
              "shortDescription": {
                "text": "API key returned in authentication response and stored in session"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/200.html",
              "properties": {
                "tags": ["security", "CWE-200"]
              }
            },
            {
              "id": "HARDCODED-CREDS",
              "name": "HardcodedCredentials",
              "shortDescription": {
                "text": "Default credentials seeded in database and displayed on login page"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/798.html",
              "properties": {
                "tags": ["security", "CWE-798"]
              }
            },
            {
              "id": "PLAINTEXT-PASSWORD",
              "name": "PlaintextPasswordStorage",
              "shortDescription": {
                "text": "Passwords stored in database without hashing"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/256.html",
              "properties": {
                "tags": ["security", "CWE-256"]
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "SQLI",
          "level": "error",
          "message": {
            "text": "SQL injection in authentication query. User-supplied 'username' and 'password' are interpolated directly into the SQL string via f-string formatting: `f\"SELECT * FROM users WHERE username = '{username}' AND password = '{password}'\"`. An attacker can bypass authentication entirely with payloads like `' OR '1'='1' --`."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "models.py"
                },
                "region": {
                  "startLine": 80,
                  "startColumn": 9
                }
              }
            }
          ],
          "properties": {
            "confidence": 1.0
          }
        },
        {
          "ruleId": "SENSITIVE-LOG",
          "level": "error",
          "message": {
            "text": "Plaintext credentials are written to the application log. The line `logger.info(f\"Login attempt: {username}:{password} from {request.remote_addr}\")` records the raw password for every login attempt. Log files are often stored with weak access controls and shipped to centralized logging systems, exposing all user passwords."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "app.py"
                },
                "region": {
                  "startLine": 123,
                  "startColumn": 9
                }
              }
            }
          ],
          "properties": {
            "confidence": 1.0
          }
        },
        {
          "ruleId": "SENSITIVE-LOG",
          "level": "warning",
          "message": {
            "text": "The authentication query containing the plaintext password is logged at DEBUG level: `logger.debug(f\"Executing query: {query}\")`. This exposes both the SQL structure and the user's password in logs."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "models.py"
                },
                "region": {
                  "startLine": 81,
                  "startColumn": 9
                }
              }
            }
          ],
          "properties": {
            "confidence": 1.0
          }
        },
        {
          "ruleId": "WEAK-CRYPTO",
          "level": "error",
          "message": {
            "text": "Session token is derived from MD5 hash of username+password: `hashlib.md5(f\"{username}{password}\".encode()).hexdigest()`. MD5 is cryptographically broken and the input is deterministic, making session tokens predictable. An attacker who knows or guesses credentials can forge session tokens without interacting with the login endpoint."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "app.py"
                },
                "region": {
                  "startLine": 132,
                  "startColumn": 13
                }
              }
            }
          ],
          "properties": {
            "confidence": 1.0
          }
        },
        {
          "ruleId": "INFO-DISCLOSURE",
          "level": "warning",
          "message": {
            "text": "The login failure response includes the username in the error message: `f\"Invalid credentials for user '{username}'\"`. This confirms the existence of user accounts to an attacker, enabling username enumeration."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "app.py"
                },
                "region": {
                  "startLine": 143,
                  "startColumn": 13
                }
              }
            }
          ],
          "properties": {
            "confidence": 1.0
          }
        },
        {
          "ruleId": "HARDCODED-SECRET",
          "level": "error",
          "message": {
            "text": "Flask secret key is hardcoded as `\"vulnerable_secret_key_123\"`. This key signs session cookies; anyone with knowledge of this value can forge arbitrary sessions, impersonating any user including admin."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "app.py"
                },
                "region": {
                  "startLine": 27,
                  "startColumn": 1
                }
              }
            }
          ],
          "properties": {
            "confidence": 1.0
          }
        },
        {
          "ruleId": "SESSION-MISCONFIG",
          "level": "warning",
          "message": {
            "text": "Session cookies are configured without Secure flag (`SESSION_COOKIE_SECURE = False`) and without HttpOnly flag (`SESSION_COOKIE_HTTPONLY = False`). This allows session cookie theft via XSS (JavaScript access) and transmission over unencrypted HTTP connections."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "app.py"
                },
                "region": {
                  "startLine": 28,
                  "startColumn": 1
                }
              }
            }
          ],
          "properties": {
            "confidence": 1.0
          }
        },
        {
          "ruleId": "SENSITIVE-EXPOSURE",
          "level": "error",
          "message": {
            "text": "The `authenticate_user` method returns the user's `api_key` in the result dictionary, which is then stored in `session['user']`. API keys should never be stored in client-side session cookies, as they can be extracted via XSS or session cookie theft."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "models.py"
                },
                "region": {
                  "startLine": 91,
                  "startColumn": 21
                }
              }
            }
          ],
          "properties": {
            "confidence": 0.95
          }
        },
        {
          "ruleId": "HARDCODED-CREDS",
          "level": "error",
          "message": {
            "text": "Default credentials (admin/admin123, guest/guest) are seeded into the database on initialization and displayed on the login page HTML. These well-known credentials provide immediate administrative access to any deployment."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "models.py"
                },
                "region": {
                  "startLine": 53,
                  "startColumn": 13
                }
              }
            },
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "app.py"
                },
                "region": {
                  "startLine": 162,
                  "startColumn": 9
                }
              }
            }
          ],
          "properties": {
            "confidence": 1.0
          }
        },
        {
          "ruleId": "PLAINTEXT-PASSWORD",
          "level": "error",
          "message": {
            "text": "Passwords are stored and compared in plaintext. The users table stores raw password strings and `authenticate_user` compares them directly via SQL equality. No hashing algorithm (bcrypt, argon2, scrypt) is applied, so a database breach exposes all passwords immediately."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "models.py"
                },
                "region": {
                  "startLine": 39,
                  "startColumn": 9
                }
              }
            }
          ],
          "properties": {
            "confidence": 1.0
          }
        }
      ]
    }
  ]
}
