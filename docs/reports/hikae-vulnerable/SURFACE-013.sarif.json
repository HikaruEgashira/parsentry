{
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/master/Schemata/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "parsentry",
          "version": "0.1.0",
          "rules": [
            {
              "id": "RCE",
              "name": "RemoteCodeExecution",
              "shortDescription": {
                "text": "Unsafe YAML deserialization with yaml.FullLoader enables arbitrary object instantiation"
              },
              "fullDescription": {
                "text": "yaml.load() is called with Loader=yaml.FullLoader on untrusted user input. FullLoader can instantiate arbitrary Python objects via YAML tags such as !!python/object/apply, !!python/object/new, and !!python/name, allowing remote code execution."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/502.html",
              "properties": {
                "tags": ["security", "CWE-502", "deserialization"]
              }
            },
            {
              "id": "INPUT-VALIDATION",
              "name": "MissingInputValidation",
              "shortDescription": {
                "text": "No validation or size limit on untrusted YAML input before deserialization"
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/20.html",
              "properties": {
                "tags": ["security", "CWE-20"]
              }
            },
            {
              "id": "INFO-DISCLOSURE",
              "name": "InformationDisclosure",
              "shortDescription": {
                "text": "Exception details leaked to client in error response"
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/209.html",
              "properties": {
                "tags": ["security", "CWE-209"]
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "RCE",
          "level": "error",
          "message": {
            "text": "Unsafe YAML deserialization at POST /api/yaml/load: yaml.load() called with yaml.FullLoader on untrusted user-supplied input (request.data). yaml.FullLoader can instantiate arbitrary Python objects via !!python/object/apply and related YAML tags, enabling remote code execution. For example, a payload like '!!python/object/apply:os.system [\"id\"]' would execute shell commands. Use yaml.safe_load() instead which only permits basic Python types."
          },
          "properties": {
            "confidence": 0.95
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "api.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 145,
                  "startColumn": 23,
                  "endLine": 145,
                  "endColumn": 68
                }
              },
              "logicalLocations": [
                {
                  "name": "load_yaml",
                  "kind": "function"
                }
              ]
            }
          ],
          "relatedLocations": [
            {
              "id": 1,
              "message": {
                "text": "Untrusted user input originates here: request.data decoded as UTF-8 without any validation or sanitization"
              },
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "api.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 141,
                  "startColumn": 17,
                  "endLine": 141,
                  "endColumn": 49
                }
              }
            }
          ],
          "fixes": [
            {
              "description": {
                "text": "Replace yaml.load(yaml_data, Loader=yaml.FullLoader) with yaml.safe_load(yaml_data) to prevent arbitrary object instantiation"
              },
              "artifactChanges": [
                {
                  "artifactLocation": {
                    "uri": "api.py",
                    "uriBaseId": "%SRCROOT%"
                  },
                  "replacements": [
                    {
                      "deletedRegion": {
                        "startLine": 145,
                        "startColumn": 23,
                        "endLine": 145,
                        "endColumn": 68
                      },
                      "insertedContent": {
                        "text": "yaml.safe_load(yaml_data)"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "ruleId": "INPUT-VALIDATION",
          "level": "warning",
          "message": {
            "text": "The endpoint reads the raw request body via request.data and passes it directly to yaml.load() without any input validation, content-type enforcement, or payload size limiting. An attacker can submit arbitrarily large YAML payloads causing denial-of-service via memory exhaustion (billion laughs / YAML bomb), or craft deeply nested structures to crash the parser. Apply Content-Length limits and validate input structure before parsing."
          },
          "properties": {
            "confidence": 0.9
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "api.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 141,
                  "startColumn": 17,
                  "endLine": 141,
                  "endColumn": 49
                }
              },
              "logicalLocations": [
                {
                  "name": "load_yaml",
                  "kind": "function"
                }
              ]
            }
          ]
        },
        {
          "ruleId": "INFO-DISCLOSURE",
          "level": "note",
          "message": {
            "text": "The except clause returns the full exception message to the client via jsonify({'error': str(e)}). This can reveal internal implementation details such as file paths, library versions, and stack context that help attackers refine exploits. Return a generic error message to clients and log exception details server-side."
          },
          "properties": {
            "confidence": 0.85
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "api.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 148,
                  "startColumn": 9,
                  "endLine": 148,
                  "endColumn": 54
                }
              },
              "logicalLocations": [
                {
                  "name": "load_yaml",
                  "kind": "function"
                }
              ]
            }
          ]
        }
      ],
      "artifacts": [
        {
          "location": {
            "uri": "api.py",
            "uriBaseId": "%SRCROOT%"
          },
          "mimeType": "text/x-python"
        }
      ]
    }
  ]
}
