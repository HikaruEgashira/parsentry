          "level": "error",
          "message": {
            "text": "The LangSmith client is instantiated with a user-configured 'api_url' (from langsmith_config.endpoint) without URL validation. An attacker who controls the tracing configuration can redirect trace data to arbitrary internal endpoints."
          },
          "locations": [
