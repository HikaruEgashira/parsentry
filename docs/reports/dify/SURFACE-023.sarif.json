{
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/main/sarif-2.1/schema/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "parsentry",
          "version": "0.1.0",
          "rules": [
            {
              "id": "SSRF",
              "name": "ServerSideRequestForgery",
              "shortDescription": {
                "text": "User-controlled URLs passed to HTTP clients without validation, enabling SSRF attacks."
              }
            },
            {
              "id": "CREDENTIAL-LEAK-ENV",
              "name": "CredentialLeakageViaEnvironment",
              "shortDescription": {
                "text": "Secrets written to process-global os.environ, risking cross-thread credential leakage."
              }
            },
            {
              "id": "PII-EXPOSURE",
              "name": "PIIExposureInTracePayload",
              "shortDescription": {
                "text": "User prompts, responses, and file URLs sent to external tracing services without sanitization."
              }
            },
            {
              "id": "INFO-DISCLOSURE",
              "name": "InformationDisclosureViaErrorMessage",
              "shortDescription": {
                "text": "Internal error details including potential connection strings or credentials exposed in exception messages."
              }
            },
            {
              "id": "WEAK-HASH",
              "name": "WeakHashForIdentifier",
              "shortDescription": {
                "text": "Use of MD5 for identifier generation, which is cryptographically weak."
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "SSRF",
          "level": "error",
          "message": {
            "text": "The Langfuse client is instantiated with a user-configured 'host' parameter passed directly to the Langfuse SDK without URL validation or allowlist checks. An attacker who controls the tracing configuration can direct requests to internal services (e.g., cloud metadata endpoints, internal APIs)."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "api/core/ops/langfuse_trace/langfuse_trace.py"
                },
