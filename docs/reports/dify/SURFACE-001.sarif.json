{
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/main/sarif-2.1/schema/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "parsentry",
          "version": "0.1.0",
          "informationUri": "https://github.com/HikaruEgashira/parsentry",
          "rules": [
            {
              "id": "BRUTE-FORCE",
              "shortDescription": {
                "text": "Missing rate limiting on security-sensitive endpoint"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/307.html"
            },
            {
              "id": "INFO-LEAK",
              "shortDescription": {
                "text": "Sensitive information disclosed in response"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/200.html"
            },
            {
              "id": "CSRF",
              "shortDescription": {
                "text": "Cross-Site Request Forgery vulnerability"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/352.html"
            },
            {
              "id": "ACCOUNT-ENUM",
              "shortDescription": {
                "text": "Account enumeration via differential responses"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/204.html"
            },
            {
              "id": "INSECURE-TOKEN",
              "shortDescription": {
                "text": "Security token exposed in insecure channel"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/522.html"
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "BRUTE-FORCE",
          "level": "error",
          "message": {
            "text": "Email code login verification endpoint lacks rate limiting on code attempts. The EmailCodeLoginApi.post() method checks the code against token_data but does not limit the number of incorrect attempts, allowing brute-force of short verification codes."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "api/controllers/console/auth/login.py"
                },
                "region": {
                  "startLine": 167,
                  "startColumn": 1
                }
              }
            }
          ],
          "properties": {
            "confidence": 0.9
          }
        },
        {
          "ruleId": "CSRF",
          "level": "error",
          "message": {
            "text": "OAuth state parameter is repurposed as invite_token instead of being used for CSRF protection. In OAuthCallback.get(), the 'state' query parameter is directly assigned to invite_token without any CSRF validation, defeating the purpose of the OAuth state parameter and enabling cross-site request forgery attacks on the OAuth flow."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "api/controllers/console/auth/oauth.py"
                },
                "region": {
                  "startLine": 83,
                  "startColumn": 1
                }
              }
            }
          ],
          "properties": {
            "confidence": 0.95
          }
        },
        {
          "ruleId": "INSECURE-TOKEN",
          "level": "error",
          "message": {
            "text": "Registration endpoint returns access/refresh token pair in the JSON response body instead of HTTP-only secure cookies. Unlike LoginApi and EmailCodeLoginApi which use set_access_token_to_cookie(), EmailRegisterResetApi returns token_pair.model_dump() directly, exposing tokens to JavaScript and XSS attacks."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "api/controllers/console/auth/email_register.py"
                },
                "region": {
                  "startLine": 126,
                  "startColumn": 1
                }
              }
            }
          ],
          "properties": {
            "confidence": 0.95
          }
        },
        {
          "ruleId": "INFO-LEAK",
          "level": "warning",
          "message": {
            "text": "Password reset endpoint returns the reset token in the HTTP response body. ResetPasswordSendEmailApi.post() returns {'result': 'success', 'data': token}, allowing any attacker who intercepts the response or exploits an XSS to obtain the reset token without access to the victim's email."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "api/controllers/console/auth/login.py"
                },
                "region": {
                  "startLine": 140,
                  "startColumn": 1
                }
              }
            }
          ],
          "properties": {
            "confidence": 0.85
          }
        },
        {
          "ruleId": "INFO-LEAK",
          "level": "warning",
          "message": {
            "text": "Email code login send endpoint returns the token in the response body. EmailCodeLoginSendEmailApi.post() returns {'result': 'success', 'data': token}. This token is used to validate the email code, and leaking it in the response enables attackers to bypass the email verification step if combined with code brute-forcing."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "api/controllers/console/auth/login.py"
                },
                "region": {
                  "startLine": 166,
                  "startColumn": 1
                }
              }
            }
          ],
          "properties": {
            "confidence": 0.8
          }
        },
        {
          "ruleId": "INFO-LEAK",
          "level": "warning",
          "message": {
            "text": "RefreshTokenApi.post() catches all exceptions and returns str(e) in the response body. Internal exception messages may contain stack traces, database details, or other sensitive implementation information that aids attackers."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "api/controllers/console/auth/login.py"
                },
                "region": {
                  "startLine": 218,
                  "startColumn": 1
                }
              }
            }
          ],
          "properties": {
            "confidence": 0.85
          }
        },
        {
          "ruleId": "ACCOUNT-ENUM",
          "level": "warning",
          "message": {
            "text": "OAuth callback returns distinct error messages for different account states: 'Account not found', 'Account is banned', and 'Workspace not found'. These differential responses allow attackers to enumerate valid accounts and determine their status by initiating OAuth flows with different email addresses."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "api/controllers/console/auth/oauth.py"
                },
                "region": {
                  "startLine": 99,
                  "startColumn": 1
                }
              }
            }
          ],
          "properties": {
            "confidence": 0.8
          }
        },
        {
          "ruleId": "BRUTE-FORCE",
          "level": "warning",
          "message": {
            "text": "RefreshTokenApi lacks @setup_required decorator and has no rate limiting or authentication beyond the refresh token cookie. An attacker with a leaked refresh token can generate unlimited access tokens without any throttling."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "api/controllers/console/auth/login.py"
                },
                "region": {
                  "startLine": 199,
                  "startColumn": 1
                }
              }
            }
          ],
          "properties": {
            "confidence": 0.7
          }
        },
        {
          "ruleId": "INFO-LEAK",
          "level": "warning",
          "message": {
            "text": "Email register send endpoint returns the verification token in the response body. EmailRegisterSendEmailApi.post() returns {'result': 'success', 'data': token}. This token combined with brute-forcing the verification code could allow account takeover."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "api/controllers/console/auth/email_register.py"
                },
                "region": {
                  "startLine": 67,
                  "startColumn": 1
                }
              }
            }
          ],
          "properties": {
            "confidence": 0.8
          }
        }
      ]
    }
  ]
}