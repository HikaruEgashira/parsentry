{
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/main/sarif-2.1/schema/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "parsentry",
          "version": "1.0.0",
          "rules": [
            {
              "id": "XSS",
              "name": "StoredCrossSkSiteScripting",
              "shortDescription": {
                "text": "Stored XSS via unsanitized memo content rendered through marked"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/79.html",
              "properties": {
                "cwe": "CWE-79"
              }
            },
            {
              "id": "INSECURE-DEPENDENCY",
              "name": "InsecureDependency",
              "shortDescription": {
                "text": "Use of marked 0.3.5 with known XSS bypass vulnerabilities"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/1395.html",
              "properties": {
                "cwe": "CWE-1395"
              }
            },
            {
              "id": "XSS-TEMPLATE",
              "name": "TemplateAutoescapeDisabled",
              "shortDescription": {
                "text": "Swig autoescape disabled allowing unescaped HTML output"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/79.html",
              "properties": {
                "cwe": "CWE-79"
              }
            },
            {
              "id": "MISSING-INPUT-VALIDATION",
              "name": "MissingInputValidation",
              "shortDescription": {
                "text": "No input validation or sanitization on memo content before storage"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/20.html",
              "properties": {
                "cwe": "CWE-20"
              }
            },
            {
              "id": "NOSQL-INJECTION",
              "name": "NoSQLInjection",
              "shortDescription": {
                "text": "Unsanitized user input passed directly to MongoDB insert"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/943.html",
              "properties": {
                "cwe": "CWE-943"
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "XSS",
          "level": "error",
          "message": {
            "text": "Stored XSS: User-supplied memo content from req.body.memo is stored in MongoDB without any sanitization, then rendered via marked() in the Swig template with autoescape disabled. An attacker can submit a memo containing malicious JavaScript (e.g., `[clickme](javascript:alert('XSS'))` or HTML injection payloads that bypass marked 0.3.5's sanitize option) that executes in every user's browser when viewing the memos page."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "app/views/memos.html"
                },
                "region": {
                  "startLine": 31,
                  "startColumn": 17,
                  "endColumn": 41
                }
              }
            }
          ],
          "relatedLocations": [
            {
              "id": 1,
              "message": {
                "text": "User input ingested from req.body.memo without validation"
              },
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "app/routes/memos.js"
                },
                "region": {
                  "startLine": 13,
                  "startColumn": 25,
                  "endColumn": 39
                }
              }
            },
            {
              "id": 2,
              "message": {
                "text": "Memo inserted into MongoDB without sanitization"
              },
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "app/data/memos-dao.js"
                },
                "region": {
                  "startLine": 23,
                  "startColumn": 9,
                  "endColumn": 85
                }
              }
            }
          ],
          "properties": {
            "confidence": 0.95
          }
        },
        {
          "ruleId": "INSECURE-DEPENDENCY",
          "level": "error",
          "message": {
            "text": "marked 0.3.5 has multiple known XSS vulnerabilities (CVE-2017-17461, CVE-2022-21680, CVE-2022-21681). The sanitize option used in server.js (line 127) is deprecated and trivially bypassable in this version. Attackers can craft markdown payloads that bypass the sanitize filter and inject arbitrary HTML/JavaScript."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "server.js"
                },
                "region": {
                  "startLine": 126,
                  "startColumn": 5,
                  "endLine": 128,
                  "endColumn": 7
                }
              }
            }
          ],
          "properties": {
            "confidence": 0.95
          }
        },
        {
          "ruleId": "XSS-TEMPLATE",
          "level": "error",
          "message": {
            "text": "Swig template engine autoescape is explicitly disabled (autoescape: false on line 137). This means all template variables including marked() output are rendered as raw HTML without escaping. Combined with the stored memo content, this creates a direct stored XSS vector affecting all users who view the memos page."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "server.js"
                },
                "region": {
                  "startLine": 137,
                  "startColumn": 9,
                  "endColumn": 25
                }
              }
            }
          ],
          "properties": {
            "confidence": 0.95
          }
        },
        {
          "ruleId": "MISSING-INPUT-VALIDATION",
          "level": "warning",
          "message": {
            "text": "The memo content from req.body.memo is passed directly to memosDAO.insert() without any input validation, length checks, or content sanitization. There is no server-side check on the type, length, or content of the memo field before it is stored in the database."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "app/routes/memos.js"
                },
                "region": {
                  "startLine": 13,
                  "startColumn": 9,
                  "endColumn": 55
                }
              }
            }
          ],
          "properties": {
            "confidence": 0.90
          }
        },
        {
          "ruleId": "NOSQL-INJECTION",
          "level": "warning",
          "message": {
            "text": "req.body.memo is passed directly into a MongoDB insert operation. Since bodyParser.urlencoded with extended:false is used, the memo field is a string and direct NoSQL operator injection via this field is limited. However, if the content type were changed to JSON (bodyParser.json is also enabled), an attacker could send an object instead of a string for the memo field, potentially causing unexpected document structures in the database."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "app/data/memos-dao.js"
                },
                "region": {
                  "startLine": 23,
                  "startColumn": 9,
                  "endColumn": 85
                }
              }
            }
          ],
          "relatedLocations": [
            {
              "id": 1,
              "message": {
                "text": "bodyParser.json() enabled, allowing JSON content type requests"
              },
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "server.js"
                },
                "region": {
                  "startLine": 71,
                  "startColumn": 5,
                  "endColumn": 29
                }
              }
            }
          ],
          "properties": {
            "confidence": 0.60
          }
        }
      ]
    }
  ]
}