{
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/master/Schemata/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "parsentry",
          "version": "0.1.0",
          "rules": [
            {
              "id": "NOAUTH",
              "name": "UnauthenticatedDatabaseConnection",
              "shortDescription": {
                "text": "MongoDB connection without authentication credentials"
              },
              "helpUri": "https://cheatsheetseries.owasp.org/cheatsheets/Database_Security_Cheat_Sheet.html"
            },
            {
              "id": "HARDCODED-SECRET",
              "name": "HardcodedSecret",
              "shortDescription": {
                "text": "Hardcoded secret value in configuration file"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/798.html"
            },
            {
              "id": "WEAK-CRYPTO",
              "name": "WeakCryptographicKey",
              "shortDescription": {
                "text": "Hardcoded cryptographic key used for encryption"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/321.html"
            },
            {
              "id": "CLEARTEXT-TRANSPORT",
              "name": "CleartextTransport",
              "shortDescription": {
                "text": "Application uses HTTP instead of HTTPS"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/319.html"
            },
            {
              "id": "MISCONFIG",
              "name": "SecurityMisconfiguration",
              "shortDescription": {
                "text": "Security headers and protections disabled"
              },
              "helpUri": "https://cheatsheetseries.owasp.org/cheatsheets/HTTP_Headers_Cheat_Sheet.html"
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "NOAUTH",
          "level": "error",
          "message": {
            "text": "MongoDB connection string 'mongodb://localhost:27017/nodegoat' uses no authentication. If the MONGODB_URI environment variable is unset, the application connects to MongoDB without any credentials. An attacker with network access to port 27017 can read, modify, or delete all data in the database."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "config/env/all.js"
                },
                "region": {
                  "startLine": 3,
                  "startColumn": 1
                }
              }
            }
          ],
          "properties": {
            "confidence": 0.95
          }
        },
        {
          "ruleId": "NOAUTH",
          "level": "error",
          "message": {
            "text": "MongoClient.connect() is called with the connection string from config without validating that authentication credentials are present. The driver does not enforce authentication by default, so a missing username/password in the URI results in an unauthenticated session."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "server.js"
                },
                "region": {
                  "startLine": 30,
                  "startColumn": 1
                }
              }
            }
          ],
          "properties": {
            "confidence": 0.9
          }
        },
        {
          "ruleId": "HARDCODED-SECRET",
          "level": "error",
          "message": {
            "text": "Session cookie secret is hardcoded as 'session_cookie_secret_key_here'. This value is predictable and shared across all deployments, allowing an attacker to forge session cookies and hijack any user's session."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "config/env/all.js"
                },
                "region": {
                  "startLine": 8,
                  "startColumn": 5
                }
              }
            }
          ],
          "properties": {
            "confidence": 0.95
          }
        },
        {
          "ruleId": "WEAK-CRYPTO",
          "level": "error",
          "message": {
            "text": "Cryptographic key is hardcoded as 'a_secure_key_for_crypto_here' and used with AES-256. A hardcoded key provides no confidentiality: anyone with source code access can decrypt all data protected by this key."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "config/env/all.js"
                },
                "region": {
                  "startLine": 9,
                  "startColumn": 5
                }
              }
            }
          ],
          "properties": {
            "confidence": 0.95
          }
        },
        {
          "ruleId": "CLEARTEXT-TRANSPORT",
          "level": "error",
          "message": {
            "text": "The server uses http.createServer() instead of https.createServer(). All traffic including session cookies, credentials, and user data is transmitted in cleartext, vulnerable to network sniffing and man-in-the-middle attacks. The HTTPS implementation exists in comments but is disabled."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "server.js"
                },
                "region": {
                  "startLine": 145,
                  "startColumn": 5
                }
              }
            }
          ],
          "properties": {
            "confidence": 0.95
          }
        },
        {
          "ruleId": "MISCONFIG",
          "level": "warning",
          "message": {
            "text": "Security headers (helmet frameguard, noCache, CSP, HSTS, nosniff) and CSRF protection are commented out. The application is missing critical HTTP security headers, leaving it vulnerable to clickjacking, XSS, MIME-sniffing, and cross-site request forgery attacks."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "server.js"
                },
                "region": {
                  "startLine": 39,
                  "startColumn": 5
                }
              }
            }
          ],
          "properties": {
            "confidence": 0.9
          }
        },
        {
          "ruleId": "MISCONFIG",
          "level": "warning",
          "message": {
            "text": "Session cookie is configured without httpOnly or secure flags. The session cookie can be accessed by client-side JavaScript (enabling XSS-based session theft) and transmitted over unencrypted HTTP connections."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "server.js"
                },
                "region": {
                  "startLine": 78,
                  "startColumn": 5
                }
              }
            }
          ],
          "properties": {
            "confidence": 0.85
          }
        }
      ]
    }
  ]
}