              "shortDescription": {
                "text": "Passwords stored in plaintext in MongoDB"
              },
              "fullDescription": {
                "text": "The addUser function stores the password directly from the request parameter into MongoDB without hashing. The bcrypt.hashSync call is commented out, leaving passwords in plaintext. Any database compromise exposes all user credentials."
              },
              "helpUri": "https://cheatsheetseries.owasp.org/cheatsheets/Password_Storage_Cheat_Sheet.html",
              "properties": {
                "tags": ["A02:2021-Cryptographic-Failures", "A07:2021-Identification-and-Authentication-Failures", "CWE-256", "CWE-522"]
              }
            },
            {
              "id": "BROKEN-AUTH-WEAK-PASSWORD-POLICY",
              "name": "WeakPasswordPolicy",
              "shortDescription": {
                "text": "Password validation allows trivially weak passwords"
              },
              "fullDescription": {
                "text": "The validateSignup function uses regex /^.{1,20}$/ which accepts any 1-20 character string as a password. The stronger regex requiring 8+ characters with mixed case and digits is commented out. This permits single-character passwords."
              },
              "helpUri": "https://cheatsheetseries.owasp.org/cheatsheets/Authentication_Cheat_Sheet.html#implement-proper-password-strength-controls",
              "properties": {
