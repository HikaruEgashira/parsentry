              },
              "helpUri": "https://cheatsheetseries.owasp.org/cheatsheets/Cross-Site_Request_Forgery_Prevention_Cheat_Sheet.html",
              "properties": {
                "tags": ["A01:2021-Broken-Access-Control", "CWE-352"]
              }
            },
            {
