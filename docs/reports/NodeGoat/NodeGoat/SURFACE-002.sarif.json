              "fullDescription": {
                "text": "The comparePassword function in validateLogin performs a direct string equality check (fromDB === fromUser) instead of using bcrypt.compareSync. Combined with plaintext storage, this confirms the entire authentication chain lacks cryptographic protection."
              },
              "helpUri": "https://cheatsheetseries.owasp.org/cheatsheets/Password_Storage_Cheat_Sheet.html",
              "properties": {
