                "text": "Hardcoded secret or credential in source code"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/798.html"
            },
            {
              "id": "HARDCODED_CRYPTO_KEY",
              "name": "HardcodedCryptoKey",
