{
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/main/sarif-2.1/schema/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "parsentry",
          "version": "1.0.0",
          "rules": [
            {
              "id": "XSS",
              "shortDescription": {
                "text": "Stored Cross-Site Scripting"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/79.html"
            },
            {
              "id": "SENSITIVE-DATA-EXPOSURE",
              "shortDescription": {
                "text": "Sensitive Data Stored in Plaintext"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/312.html"
            },
            {
              "id": "REDOS",
              "shortDescription": {
                "text": "Regular Expression Denial of Service"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/1333.html"
            },
            {
              "id": "XSS-CONTEXT",
              "shortDescription": {
                "text": "Incorrect Output Encoding Context"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/838.html"
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "XSS",
          "level": "error",
          "message": {
            "text": "User-supplied profile fields (firstName, lastName, address, etc.) are stored in MongoDB via updateUser() without any sanitization or encoding. When these values are rendered in the profile template via res.render('profile', ...user), they produce stored XSS. An attacker can inject script tags into firstName or other fields that execute in any user's browser viewing the profile."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "app/routes/profile.js"
                },
                "region": {
                  "startLine": 82,
                  "endLine": 91
                }
              }
            }
          ],
          "properties": {
            "confidence": 0.95
          }
        },
        {
          "ruleId": "XSS",
          "level": "error",
          "message": {
            "text": "In the bankRouting validation error path, user-supplied values (firstName, lastName, ssn, dob, address, bankAcc, bankRouting) are passed directly to res.render() without sanitization. This reflects unsanitized input back into the rendered HTML, enabling reflected XSS."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "app/routes/profile.js"
                },
                "region": {
                  "startLine": 64,
                  "endLine": 76
                }
              }
            }
          ],
          "properties": {
            "confidence": 0.9
          }
        },
        {
          "ruleId": "XSS-CONTEXT",
          "level": "warning",
          "message": {
            "text": "The website field is encoded using encodeForHTML() but is used in the context of a URL href attribute. This is the wrong encoding context — encodeForURL() should be used instead. An attacker can craft a javascript: URI that bypasses HTML encoding but executes when clicked as a link."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "app/routes/profile.js"
                },
                "region": {
                  "startLine": 28,
                  "endLine": 28
                }
              }
            }
          ],
          "properties": {
            "confidence": 0.9
          }
        },
        {
          "ruleId": "SENSITIVE-DATA-EXPOSURE",
          "level": "error",
          "message": {
            "text": "SSN and date of birth are stored in plaintext in MongoDB. The encryption code in profile-dao.js is commented out (lines 15-40). An attacker who gains database access obtains all users' SSNs and dates of birth in cleartext, enabling identity theft."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "app/data/profile-dao.js"
                },
                "region": {
                  "startLine": 61,
                  "endLine": 66
                }
              }
            }
          ],
          "properties": {
            "confidence": 0.95
          }
        },
        {
          "ruleId": "REDOS",
          "level": "error",
          "message": {
            "text": "The regex /([0-9]+)+\\#/ used to validate bankRouting contains nested quantifiers ([0-9]+)+, making it vulnerable to catastrophic backtracking (ReDoS). An attacker can send a specially crafted bankRouting value like '0000000000000000000000000000!' to cause the server to hang, consuming 100% CPU."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "app/routes/profile.js"
                },
                "region": {
                  "startLine": 59,
                  "endLine": 59
                }
              }
            }
          ],
          "properties": {
            "confidence": 0.95
          }
        },
        {
          "ruleId": "SENSITIVE-DATA-EXPOSURE",
          "level": "warning",
          "message": {
            "text": "Bank account number (bankAcc) and bank routing number (bankRouting) are stored in plaintext in MongoDB without encryption. The updateUser function stores these financial fields directly, exposing them to anyone with database access."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "app/data/profile-dao.js"
                },
                "region": {
                  "startLine": 55,
                  "endLine": 60
                }
              }
            }
          ],
          "properties": {
            "confidence": 0.85
          }
        }
      ]
    }
  ]
}