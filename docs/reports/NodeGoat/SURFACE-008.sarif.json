          "ruleId": "OPEN-REDIRECT",
          "level": "error",
          "message": {
            "text": "The /learn endpoint takes a URL directly from the query string parameter 'url' and passes it to res.redirect() without any validation or allowlisting. An attacker can craft a link such as /learn?url=https://evil.com to redirect authenticated users to a malicious site, enabling phishing attacks."
          },
          "locations": [
            {
              "physicalLocation": {
