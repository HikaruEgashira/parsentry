{
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/main/sarif-2.1/schema/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "parsentry",
          "version": "0.1.0",
          "informationUri": "https://github.com/HikaruEgashira/parsentry",
          "rules": [
            {
              "id": "NOSQLI-001",
              "name": "NoSQLInjectionViaWhereClause",
              "shortDescription": {
                "text": "NoSQL injection via unsanitized user input in MongoDB $where clause"
              },
              "fullDescription": {
                "text": "The 'threshold' query parameter is interpolated directly into a MongoDB $where JavaScript string without sanitization or parameterization. An attacker can inject arbitrary JavaScript code that executes within the MongoDB engine, enabling data exfiltration, authentication bypass, or denial of service (e.g., infinite loops)."
              },
              "helpUri": "https://owasp.org/www-project-web-security-testing-guide/latest/4-Web_Application_Security_Testing/07-Input_Validation_Testing/05.6-Testing_for_NoSQL_Injection",
              "properties": {
                "tags": [
                  "security",
                  "injection",
                  "nosql",
                  "mongodb",
                  "CWE-943"
                ],
                "precision": "very-high"
              }
            },
            {
              "id": "NOSQLI-002",
              "name": "NoSQLInjectionDoS",
              "shortDescription": {
                "text": "Denial of service via JavaScript injection in MongoDB $where clause"
              },
              "fullDescription": {
                "text": "The unsanitized threshold parameter allows injection of JavaScript that runs inside MongoDB's server-side evaluation. An attacker can inject an infinite loop (e.g., `0'; while(true){}; '`) to exhaust server resources and cause denial of service."
              },
              "helpUri": "https://owasp.org/www-project-web-security-testing-guide/latest/4-Web_Application_Security_Testing/07-Input_Validation_Testing/05.6-Testing_for_NoSQL_Injection",
              "properties": {
                "tags": [
                  "security",
                  "injection",
                  "nosql",
                  "dos",
                  "CWE-400"
                ],
                "precision": "very-high"
              }
            },
            {
              "id": "IDOR-001",
              "name": "InsecureDirectObjectReference",
              "shortDescription": {
                "text": "User ID taken from URL parameter instead of authenticated session"
              },
              "fullDescription": {
                "text": "The displayAllocations handler reads userId from req.params (URL path) rather than from req.session. This allows any authenticated user to view other users' allocation data by modifying the userId in the URL, constituting an Insecure Direct Object Reference (IDOR) vulnerability."
              },
              "helpUri": "https://owasp.org/www-project-web-security-testing-guide/latest/4-Web_Application_Security_Testing/05-Authorization_Testing/04-Testing_for_Insecure_Direct_Object_References",
              "properties": {
                "tags": [
                  "security",
                  "authorization",
                  "idor",
                  "CWE-639"
                ],
                "precision": "very-high"
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "NOSQLI-001",
          "ruleIndex": 0,
          "level": "error",
          "message": {
            "text": "The 'threshold' query parameter is string-interpolated directly into a MongoDB $where clause: `this.userId == ${parsedUserId} && this.stocks > '${threshold}'`. An attacker can inject JavaScript code (e.g., threshold=`1'; return 1 == '1`) to bypass query filters and access unauthorized data."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "app/data/allocations-dao.js",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
