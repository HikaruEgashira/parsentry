          "level": "error",
          "message": {
            "text": "The displayAllocations handler extracts userId from req.params (URL path segment) at line 17 instead of from the authenticated session (req.session.userId). Any authenticated user can enumerate and access other users' allocation data by modifying the userId in the request URL."
          },
          "locations": [
