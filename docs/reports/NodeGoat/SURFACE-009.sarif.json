{
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/main/sarif-2.1/schema/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "parsentry",
          "version": "1.0.0",
          "rules": [
            {
              "id": "SSRF",
              "shortDescription": {
                "text": "Server-Side Request Forgery"
              },
              "helpUri": "https://owasp.org/Top10/A10_2021-Server-Side_Request_Forgery_%28SSRF%29/"
            },
            {
              "id": "XSS",
              "shortDescription": {
                "text": "Cross-Site Scripting"
              },
              "helpUri": "https://owasp.org/www-community/attacks/xss/"
            },
            {
              "id": "OPEN-REDIRECT",
              "shortDescription": {
                "text": "Unvalidated Redirect"
              },
              "helpUri": "https://cheatsheetseries.owasp.org/cheatsheets/Unvalidated_Redirects_and_Forwards_Cheat_Sheet.html"
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "SSRF",
          "level": "error",
          "message": {
            "text": "Server-Side Request Forgery via user-controlled URL. The `req.query.url` parameter is directly concatenated with `req.query.symbol` and passed to `needle.get()` without any validation or allowlisting. An attacker can supply an arbitrary URL (e.g., http://169.254.169.254/latest/meta-data/ for cloud metadata, or internal service URLs) to make the server issue requests to internal or external resources on the attacker's behalf."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "app/routes/research.js"
                },
                "region": {
                  "startLine": 15,
                  "startColumn": 13,
                  "endLine": 16,
                  "endColumn": 58
                }
              }
            }
          ],
          "properties": {
            "confidence": 0.95
          }
        },
        {
          "ruleId": "XSS",
          "level": "error",
          "message": {
            "text": "Reflected Cross-Site Scripting via unescaped response body. The response body from the external `needle.get()` request is written directly to the HTTP response via `res.write(body)` with Content-Type `text/html` and no output encoding or sanitization. If the attacker controls the target URL (via the SSRF above) or the remote server returns malicious HTML/JavaScript, it will be rendered in the victim's browser. This is a second-order XSS chained with the SSRF."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "app/routes/research.js"
                },
                "region": {
                  "startLine": 25,
                  "startColumn": 21,
                  "endLine": 25,
                  "endColumn": 37
                }
              }
            }
          ],
          "properties": {
            "confidence": 0.95
          }
        },
        {
          "ruleId": "OPEN-REDIRECT",
          "level": "warning",
          "message": {
            "text": "Unvalidated redirect on the `/learn` route. The `req.query.url` value is passed directly to `res.redirect()` without any validation or allowlisting. An attacker can craft a link such as `/learn?url=https://evil.com` to redirect authenticated users to a phishing site. This is a classic A10 (Unvalidated Redirects and Forwards) vulnerability."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "app/routes/index.js"
                },
                "region": {
                  "startLine": 72,
                  "startColumn": 16,
                  "endLine": 72,
                  "endColumn": 45
                }
              }
            }
          ],
          "properties": {
            "confidence": 0.95
          }
        }
      ]
    }
  ]
}