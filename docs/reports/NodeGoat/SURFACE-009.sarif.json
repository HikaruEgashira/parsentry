                "text": "Unsanitized 'threshold' parameter received from query string"
              },
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "app/routes/allocations.js",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 19,
                  "startColumn": 9,
                  "endLine": 21,
                  "endColumn": 10
                }
              }
            },
            {
              "id": 2,
              "message": {
                "text": "Threshold passed to DAO without validation"
              },
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "app/routes/allocations.js",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 23,
                  "startColumn": 9,
                  "endLine": 23,
                  "endColumn": 78
                }
              }
            }
          ],
          "fixes": [
            {
              "description": {
                "text": "Parse threshold as integer and validate range before use in $where clause"
              },
              "artifactChanges": [
                {
                  "artifactLocation": {
                    "uri": "app/data/allocations-dao.js",
                    "uriBaseId": "%SRCROOT%"
                  },
                  "replacements": [
                    {
                      "deletedRegion": {
                        "startLine": 77,
                        "startColumn": 1,
                        "endLine": 79,
                        "endColumn": 1
                      },
                      "insertedContent": {
                        "text": "                const parsedThreshold = parseInt(threshold, 10);\n                if (parsedThreshold >= 0 && parsedThreshold <= 99) {\n                    return {$where: `this.userId == ${parsedUserId} && this.stocks > ${parsedThreshold}`};\n                }\n                throw `The user supplied threshold: ${parsedThreshold} was not valid.`;\n"
                      }
                    }
                  ]
                }
              ]
            }
          ],
          "properties": {
            "confidence": 0.95
          }
        },
        {
          "ruleId": "NOSQLI-002",
          "ruleIndex": 1,
          "level": "error",
          "message": {
            "text": "The $where clause accepts arbitrary JavaScript from the 'threshold' parameter. An attacker can inject `0'; while(true){}; '` to cause an infinite loop inside MongoDB's JavaScript engine, resulting in denial of service."
          },
          "locations": [
