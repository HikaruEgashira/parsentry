{
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/main/sarif-2.1/schema/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "parsentry",
          "version": "0.1.0",
          "rules": [
            {
              "id": "SESSION-WEAK-SECRET",
              "shortDescription": {
                "text": "Hardcoded weak session secret"
              },
              "helpUri": "https://cheatsheetseries.owasp.org/cheatsheets/Session_Management_Cheat_Sheet.html"
            },
            {
              "id": "SESSION-NO-HTTPONLY",
              "shortDescription": {
                "text": "Session cookie missing httpOnly flag"
              },
              "helpUri": "https://cheatsheetseries.owasp.org/cheatsheets/Session_Management_Cheat_Sheet.html"
            },
            {
              "id": "SESSION-NO-SECURE",
              "shortDescription": {
                "text": "Session cookie missing secure flag"
              },
              "helpUri": "https://cheatsheetseries.owasp.org/cheatsheets/Session_Management_Cheat_Sheet.html"
            },
            {
              "id": "SESSION-NO-EXPIRY",
              "shortDescription": {
                "text": "Session cookie missing maxAge / expires"
              },
              "helpUri": "https://cheatsheetseries.owasp.org/cheatsheets/Session_Management_Cheat_Sheet.html"
            },
            {
              "id": "SESSION-DEFAULT-NAME",
              "shortDescription": {
                "text": "Session uses default cookie name exposing framework identity"
              },
              "helpUri": "https://cheatsheetseries.owasp.org/cheatsheets/Session_Management_Cheat_Sheet.html"
            },
            {
              "id": "TRANSPORT-HTTP",
              "shortDescription": {
                "text": "Application served over insecure HTTP"
              },
              "helpUri": "https://cheatsheetseries.owasp.org/cheatsheets/Transport_Layer_Security_Cheat_Sheet.html"
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "SESSION-WEAK-SECRET",
          "level": "error",
          "message": {
            "text": "The session secret is a hardcoded plaintext string 'session_cookie_secret_key_here' in config/env/all.js. This weak, predictable secret allows an attacker to forge session cookies and hijack any user session. The secret should be a high-entropy value loaded from an environment variable."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "config/env/all.js"
                },
                "region": {
                  "startLine": 8,
                  "startColumn": 5
                }
              }
            }
          ],
          "properties": {
            "confidence": 0.95
          }
        },
        {
          "ruleId": "SESSION-NO-HTTPONLY",
          "level": "error",
          "message": {
            "text": "The express-session configuration does not set the httpOnly cookie flag. Without httpOnly, session cookies are accessible to client-side JavaScript, enabling session theft via XSS attacks. The fix (cookie: { httpOnly: true }) is present in a comment block but not active."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "server.js"
                },
                "region": {
                  "startLine": 78,
                  "endLine": 102
                }
              }
            }
          ],
          "properties": {
            "confidence": 0.95
          }
        },
        {
          "ruleId": "SESSION-NO-SECURE",
          "level": "error",
          "message": {
            "text": "The express-session configuration does not set the secure cookie flag. Without secure: true, session cookies are transmitted over plaintext HTTP, allowing interception via network sniffing (session hijacking). The fix is commented out in server.js line 98."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "server.js"
                },
                "region": {
                  "startLine": 78,
                  "endLine": 102
                }
              }
            }
          ],
          "properties": {
            "confidence": 0.95
          }
        },
        {
          "ruleId": "SESSION-NO-EXPIRY",
          "level": "warning",
          "message": {
            "text": "The session cookie has no maxAge or expires set. Sessions persist indefinitely until the browser is closed (or not at all if the session store persists). This increases the window for session fixation and replay attacks. A TODO on line 96 acknowledges the missing maxAge."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "server.js"
                },
                "region": {
                  "startLine": 78,
                  "endLine": 102
                }
              }
            }
          ],
          "properties": {
            "confidence": 0.90
          }
        },
        {
          "ruleId": "SESSION-DEFAULT-NAME",
          "level": "warning",
          "message": {
            "text": "The session uses the default cookie name 'connect.sid', which reveals the application is built on Express/Connect. An attacker can use this to fingerprint the framework and target known vulnerabilities. The fix (key: 'sessionId') is commented out on line 89."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "server.js"
                },
                "region": {
                  "startLine": 78,
                  "endLine": 102
                }
              }
            }
          ],
          "properties": {
            "confidence": 0.85
          }
        },
        {
          "ruleId": "TRANSPORT-HTTP",
          "level": "error",
          "message": {
            "text": "The application is served over plain HTTP (http.createServer on line 145). All traffic including session cookies is transmitted in cleartext. The HTTPS server setup exists but is commented out (lines 149-155). Without HTTPS, even adding the secure cookie flag would break sessions rather than protect them."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "server.js"
                },
                "region": {
                  "startLine": 145,
                  "startColumn": 5
                }
              }
            }
          ],
          "properties": {
            "confidence": 0.95
          }
        }
      ]
    }
  ]
}